---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = "About";
const description = "Learn about the Guild Presidents Leadership Academy - East Africa's premier youth leadership institution.";
---

<Base title={title} description={description}>
  <Navbar />
  
  <!-- Hero -->
  <section class="min-h-[60vh] bg-gpla-navy px-12 pt-32 pb-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[45%] h-full bg-gpla-green" style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">ABOUT US</p>
      <h1 class="font-display text-white text-[72px] leading-tight">
        Forging Leaders for<br />
        Democratic East Africa
      </h1>
    </div>
  </section>

  <!-- Content -->
  <section class="px-12 py-24">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display text-gpla-navy text-[40px] mb-6">Our Story</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          The Guild Presidents Leadership Academy (GPLA) is a prestigious regional institution based at Makerere University, Uganda — widely recognized as the birthplace of African student activism.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          Since our founding, we've convened over 700 youth leaders from 6 countries across East Africa. Our programs have hosted sitting Vice Presidents, former Heads of State, EU Ambassadors, and Electoral Commission Chairpersons as speakers and mentors.
        </p>
        <p class="text-gray-600 leading-relaxed">
          We believe that outgoing Guild Presidents represent a untapped reservoir of leadership talent. By providing them with the knowledge, values, and networks needed for effective governance, we're building the next generation of East Africa's democratic leaders.
        </p>
      </div>
      <div>
        <div class="bg-gpla-navy p-10 rounded-xl">
          <p class="text-white text-2xl italic mb-6">"History has been made."</p>
          <cite class="text-gpla-gold not-italic block">— Demiano Masesa<br />Executive Director, GPLA</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="px-12 py-24 bg-gpla-light">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display text-gpla-green text-[24px] mb-4">OUR MISSION</h2>
        <p class="text-gray-600 leading-relaxed">
          To equip outgoing Guild Presidents with the knowledge, values, and professional networks required to drive democratic transformation across East Africa.
        </p>
      </div>
      <div>
        <h2 class="font-display text-gpla-navy text-[24px] mb-4">OUR VISION</h2>
        <p class="text-gray-600 leading-relaxed">
          A unified East Africa where ethical youth leadership thrives through strong democratic institutions and active citizen participation.
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="px-12 py-24">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-gpla-navy text-[48px] text-center mb-12">OUR TEAM</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-32 h-32 bg-gradient-to-br from-gpla-navy to-gpla-green rounded-full mx-auto mb-4"></div>
          <h3 class="font-display text-xl text-gpla-navy">Demiano Masesa</h3>
          <p class="text-gray-500 text-sm">Executive Director</p>
        </div>
        <div class="text-center">
          <div class="w-32 h-32 bg-gradient-to-br from-gpla-navy to-gpla-green rounded-full mx-auto mb-4"></div>
          <h3 class="font-display text-xl text-gpla-navy">Dr. Sarah Kemigisa</h3>
          <p class="text-gray-500 text-sm">Programs Director</p>
        </div>
        <div class="text-center">
          <div class="w-32 h-32 bg-gradient-to-br from-gpla-navy to-gpla-green rounded-full mx-auto mb-4"></div>
          <h3 class="font-display text-xl text-gpla-navy">James Ochieng</h3>
          <p class="text-gray-500 text-sm">Operations Manager</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>