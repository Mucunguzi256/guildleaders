---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Home">
  <Navbar />

  <!-- Hero Section -->
  <!-- VIDEO: drop hero-bg.mp4 into /public/videos/ to activate -->
  <section class="hero relative min-h-screen overflow-hidden flex items-center">
    <!-- VIDEO BACKGROUND — client to provide video file -->
    <div class="hero-video-wrapper absolute inset-0 z-0">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        class="w-full h-full object-cover opacity-30"
        poster="/images/hero-poster.jpg"
      >
        <!-- Client to add: <source src="/videos/hero-bg.mp4" type="video/mp4"> -->
        <!-- Fallback gradient shown until video is provided -->
      </video>
      <!-- Gradient overlay — always visible, darkens video -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#132d82]/95 via-[#132d82]/80 to-[#389a29]/60"></div>
    </div>

    <!-- Hero content sits above video -->
    <div class="relative z-10 max-w-[55%] px-4 md:px-12 py-20 md:py-32">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">Est. Makerere University, Kampala</p>
      <h1 class="font-display text-white text-[48px] md:text-[72px] lg:text-[96px] leading-[0.95] mb-6">
        SHAPING<br />
        EAST AFRICA'S<br />
        NEXT LEADERS.
      </h1>
      <p class="text-white/85 text-lg max-w-[500px] mb-8 leading-relaxed">
        Equipping outgoing Guild Presidents with the knowledge, values, and networks to transform governance across East Africa.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/guildleaders/programs" class="bg-gpla-green text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">
          Our Programs
        </a>
        <a href="/guildleaders/summit" class="border-2 border-white text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold inline-block hover:bg-white hover:text-gpla-navy transition-all">
          View Summit
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="bg-gpla-green px-4 md:px-12 py-10 md:py-16" data-animate>
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 text-center">
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="700" data-suffix="+" class="stat-number">0+</span></div>
        <div class="text-white/85 text-xs md:text-sm">Former Leaders Convened</div>
      </div>
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="4" class="stat-number">0</span></div>
        <div class="text-white/85 text-xs md:text-sm">Flagship Programs</div>
      </div>
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="6" class="stat-number">0</span></div>
        <div class="text-white/85 text-xs md:text-sm">Countries Represented</div>
      </div>
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="1" class="stat-number">0</span></div>
        <div class="text-white/85 text-xs md:text-sm">Regional Summit Annually</div>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="px-4 md:px-12 py-16 md:py-24 bg-gpla-light">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="bg-gpla-navy p-8 md:p-12 relative">
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gpla-green;"></div>
        <p class="text-white text-xl md:text-2xl italic leading-relaxed">"History has been made."</p>
        <cite class="block mt-6 text-gpla-gold text-base not-italic">— Demiano Masesa, Executive Director, GPLA</cite>
      </div>
      <div>
        <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-3">WHO WE ARE</p>
        <h2 class="font-display text-gpla-navy text-[32px] md:text-[48px] leading-tight mb-5">Forging Leaders for a Democratic East Africa</h2>
        <p class="text-gray-600 text-base leading-relaxed mb-6">
          The Guild Presidents Leadership Academy (GPLA) is a prestigious regional institution based at Makerere University, Uganda — the birthplace of African student activism.
        </p>
        <p class="text-gray-600 text-base leading-relaxed mb-6">
          We've convened over 700 youth leaders from 6 countries, hosting sitting Vice Presidents, former Heads of State, EU Ambassadors, and Electoral Commission Chairpersons.
        </p>
        <a href="/guildleaders/about" class="text-gpla-green font-semibold inline-flex items-center gap-2">
          Read Our Full Story →
        </a>
      </div>
    </div>
  </section>

  <!-- Pattern Divider Thin -->
  <div class="h-10 w-full" style="background: linear-gradient(90deg, #389a29 0%, #389a29 16%, #132d82 16%, #132d82 32%, #F5A623 32%, #F5A623 48%, #ffffff 48%, #ffffff 64%, #389a29 64%, #389a29 80%, #132d82 80%, #132d82 100%);"></div>

  <!-- Our Summits — Interactive CrewAI Style -->
  <section class="summits-interactive py-24 bg-[var(--bg-section-alt)]" data-animate>
    <div class="container mx-auto px-6">
      
      <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-2">Our Summits</p>
      <h2 class="font-display text-5xl text-gpla-navy mb-16">
        THREE YEARS. ONE MOVEMENT.
      </h2>

      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <!-- Tab list — left -->
        <div class="tab-list flex flex-col gap-0 w-64 flex-shrink-0">
          
          <button class="summit-tab active" data-tab="2026">
            <span class="tab-year font-display text-4xl">2026</span>
            <span class="tab-label">3rd Annual Summit</span>
            <span class="tab-badge upcoming">UPCOMING</span>
          </button>
          
          <button class="summit-tab" data-tab="2025">
            <span class="tab-year font-display text-4xl">2025</span>
            <span class="tab-label">2nd Annual Summit</span>
          </button>
          
          <button class="summit-tab" data-tab="2024">
            <span class="tab-year font-display text-4xl">2024</span>
            <span class="tab-label">Inaugural Summit</span>
          </button>
          
        </div>

        <!-- Content panels — right -->
        <div class="tab-content flex-1">
          
          <div id="panel-2026" class="summit-panel active">
            <span class="text-gpla-gold font-bold uppercase tracking-widest text-xs">Upcoming · 23–24 July 2026</span>
            <h3 class="font-display text-4xl text-gpla-navy mt-2 mb-4">
              3RD ANNUAL EAST AFRICAN GUILD LEADERS' SUMMIT
            </h3>
            <p class="text-lg text-[var(--text-muted)] mb-6">
              Youth Leadership, Production, and Regional Integration: Building a Competitive East Africa in a Changing Global Order
            </p>
            <div class="summit-meta grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              <div class="meta-item">
                <span class="label text-xs font-bold uppercase tracking-widest text-gpla-green">Chief Guest</span>
                <span class="value block text-gpla-navy font-semibold text-lg">H.E. Yoweri Kaguta Museveni</span>
                <span class="sub text-[var(--text-muted)] text-sm">President of Uganda & EAC Chairperson</span>
              </div>
              <div class="meta-item">
                <span class="label text-xs font-bold uppercase tracking-widest text-gpla-green">Venue</span>
                <span class="value block text-gpla-navy font-semibold text-lg">Freedom Square</span>
                <span class="sub text-[var(--text-muted)] text-sm">Makerere University, Kampala</span>
              </div>
            </div>
            <div class="flex flex-wrap gap-4">
              <a href="/guildleaders/summit/2026" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">Register Interest →</a>
              <a href="/guildleaders/summit/2026#partner" class="border-2 border-gpla-navy text-gpla-navy px-6 py-3 rounded-full font-semibold inline-block hover:bg-gpla-navy hover:text-white transition-all">Become a Partner →</a>
            </div>
          </div>

          <div id="panel-2025" class="summit-panel hidden">
            <span class="text-gpla-green font-bold uppercase tracking-widest text-xs">2025 · Makerere University</span>
            <h3 class="font-display text-4xl text-gpla-navy mt-2 mb-4">
              2ND ANNUAL GUILD LEADERS' SUMMIT
            </h3>
            <p class="text-lg text-[var(--text-muted)] mb-6">
              Democratic Governance and People-to-People Integration
            </p>
            <div class="summit-meta grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              <div class="meta-item">
                <span class="label text-xs font-bold uppercase tracking-widest text-gpla-green">Chief Guest</span>
                <span class="value block text-gpla-navy font-semibold text-lg">HE. Uhuru Kenyatta</span>
                <span class="sub text-[var(--text-muted)] text-sm">Former President, Kenya</span>
              </div>
              <div class="meta-item">
                <span class="label text-xs font-bold uppercase tracking-widest text-gpla-green">Attendees</span>
                <span class="value block text-gpla-navy font-semibold text-lg">700+</span>
                <span class="sub text-[var(--text-muted)] text-sm">Leaders from 6 countries</span>
              </div>
            </div>
            <a href="/guildleaders/summit/2025" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">View Full Report →</a>
          </div>

          <div id="panel-2024" class="summit-panel hidden">
            <span class="text-gpla-green font-bold uppercase tracking-widest text-xs">April 15, 2024 · Makerere University</span>
            <h3 class="font-display text-4xl text-gpla-navy mt-2 mb-4">
              INAUGURAL GUILD LEADERS' SUMMIT
            </h3>
            <p class="text-lg text-[var(--text-muted)] mb-6">
              Legacy and Leadership Continuum: The Power of Knowledge and Cross-Generational Learning
            </p>
            <div class="summit-meta grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
              <div class="meta-item">
                <span class="label text-xs font-bold uppercase tracking-widest text-gpla-green">Chief Guest</span>
                <span class="value block text-gpla-navy font-semibold text-lg">HE. Jakaya Mrisho Kikwete</span>
                <span class="sub text-[var(--text-muted)] text-sm">Former President, Tanzania · Now Patron</span>
              </div>
              <div class="meta-item">
                <span class="label text-xs font-bold uppercase tracking-widest text-gpla-green">Attendees</span>
                <span class="value block text-gpla-navy font-semibold text-lg">700+</span>
                <span class="sub text-[var(--text-muted)] text-sm">Historic first convening</span>
              </div>
            </div>
            <a href="/guildleaders/summit/2024" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">View Full Report →</a>
          </div>
          
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.summit-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        document.querySelectorAll('.summit-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.summit-panel').forEach(p => { p.classList.add('hidden'); p.classList.remove('active'); });
        tab.classList.add('active');
        const panel = document.getElementById('panel-' + target);
        panel.classList.remove('hidden');
        requestAnimationFrame(() => panel.classList.add('active'));
      });
    });
  </script>

  <!-- Programs — Interactive -->
  <section class="programs-interactive py-24 bg-gpla-navy" data-animate>
    <div class="container mx-auto px-6">
      
      <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-2">Our Programs</p>
      <h2 class="font-display text-5xl text-white mb-16">
        BUILD YOUR LEADERSHIP TOOLKIT
      </h2>

      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <!-- Tab list — left -->
        <div class="tab-list flex flex-col gap-0 w-64 flex-shrink-0">
          
          <button class="program-tab active" data-tab="t lb">
            <span class="tab-icon w-10 h-10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75l-6 4.5V6l6 6.75z" fill="#F5A623" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 12.75l6 4.5V6l-6 6.75z" />
              </svg>
            </span>
            <span class="tab-label text-white">TLB</span>
            <span class="tab-sub text-white/50 text-sm">Leadership Bootcamp</span>
          </button>
          
          <button class="program-tab" data-tab="pgil">
            <span class="tab-icon w-10 h-10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </span>
            <span class="tab-label text-white">PGIL</span>
            <span class="tab-sub text-white/50 text-sm">Policy Lab</span>
          </button>
          
          <button class="program-tab" data-tab="herpower">
            <span class="tab-icon w-10 h-10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" fill="#F5A623" />
              </svg>
            </span>
            <span class="tab-label text-white">HERPower</span>
            <span class="tab-sub text-white/50 text-sm">Women's Fellowship</span>
          </button>
          
          <button class="program-tab" data-tab="summit">
            <span class="tab-icon w-10 h-10 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
              </svg>
            </span>
            <span class="tab-label text-white">Summit</span>
            <span class="tab-sub text-white/50 text-sm">Annual Gathering</span>
          </button>
          
        </div>

        <!-- Content panels — right -->
        <div class="tab-content flex-1">
          
          <div id="panel-tlb" class="program-panel active">
            <h3 class="font-display text-4xl text-white mt-2 mb-4">
              Transformational Leadership Bootcamp (TLB)
            </h3>
            <div class="flex gap-4 mb-6 text-sm text-white/70">
              <span class="bg-white/10 px-3 py-1 rounded-full">5 Days</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Residential</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Intensive</span>
            </div>
            <p class="text-lg text-white/80 mb-6">
              A rigorous 5-day residential program building essential leadership skills for effective student governance. Participants engage in strategic planning, public speaking, crisis management, and team dynamics training.
            </p>
            <div class="mb-8">
              <h4 class="text-gpla-gold font-semibold uppercase tracking-widest text-sm mb-3">Key Outcomes</h4>
              <ul class="space-y-2 text-white/80">
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Master strategic planning and decision-making frameworks</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Develop crisis management and conflict resolution skills</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Build a lifelong network of 100+ fellow guild leaders</li>
              </ul>
            </div>
            <a href="/guildleaders/programs" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">Learn More →</a>
          </div>

          <div id="panel-pgil" class="program-panel hidden">
            <h3 class="font-display text-4xl text-white mt-2 mb-4">
              Policy & Governance Incubation Lab (PGIL)
            </h3>
            <div class="flex gap-4 mb-6 text-sm text-white/70">
              <span class="bg-white/10 px-3 py-1 rounded-full">8 Weeks</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Hybrid</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Research-Focused</span>
            </div>
            <p class="text-lg text-white/80 mb-6">
              8-week intensive program building practical policy analysis and advocacy skills. Fellows work on real policy challenges facing East Africa, producing actionable research for regional institutions.
            </p>
            <div class="mb-8">
              <h4 class="text-gpla-gold font-semibold uppercase tracking-widest text-sm mb-3">Key Outcomes</h4>
              <ul class="space-y-2 text-white/80">
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Produce a publishable policy brief on a regional issue</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Present research to senior policymakers and diplomats</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Join the alumni network of policy practitioners</li>
              </ul>
            </div>
            <a href="/guildleaders/programs" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">Learn More →</a>
          </div>

          <div id="panel-herpower" class="program-panel hidden">
            <h3 class="font-display text-4xl text-white mt-2 mb-4">
              HERPower Fellowship
            </h3>
            <div class="flex gap-4 mb-6 text-sm text-white/70">
              <span class="bg-white/10 px-3 py-1 rounded-full">6 Months</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Mentorship</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Women Only</span>
            </div>
            <p class="text-lg text-white/80 mb-6">
              Specialized fellowship for young women passionate about political leadership. HERPower provides mentorship, networking, and capacity building to increase women's representation in student governance and beyond.
            </p>
            <div class="mb-8">
              <h4 class="text-gpla-gold font-semibold uppercase tracking-widest text-sm mb-3">Key Outcomes</h4>
              <ul class="space-y-2 text-white/80">
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> 1-on-1 mentorship from established female leaders</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Leadership coaching and personal branding training</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Access to HERPower alumnae network of 200+ women</li>
              </ul>
            </div>
            <a href="/guildleaders/programs" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">Learn More →</a>
          </div>

          <div id="panel-summit" class="program-panel hidden">
            <h3 class="font-display text-4xl text-white mt-2 mb-4">
              Guild Leaders' Summit + Guild Voice
            </h3>
            <div class="flex gap-4 mb-6 text-sm text-white/70">
              <span class="bg-white/10 px-3 py-1 rounded-full">2 Days</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">Annual</span>
              <span class="bg-white/10 px-3 py-1 rounded-full">700+ Attendees</span>
            </div>
            <p class="text-lg text-white/80 mb-6">
              Annual flagship gathering bringing together Guild Presidents from across East Africa. The Summit features high-level plenary sessions, workshops, and the Guild Voice policy platform where youth voices are amplified.
            </p>
            <div class="mb-8">
              <h4 class="text-gpla-gold font-semibold uppercase tracking-widest text-sm mb-3">Key Outcomes</h4>
              <ul class="space-y-2 text-white/80">
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Address heads of state, ministers, and regional leaders</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Publish the Guild Voice Declaration for EAC policymakers</li>
                <li class="flex items-start gap-2"><span class="text-gpla-green">✓</span> Build cross-border networks with 700+ peer leaders</li>
              </ul>
            </div>
            <a href="/guildleaders/summit" class="bg-gpla-green text-white px-6 py-3 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">Learn More →</a>
          </div>
          
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.program-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        document.querySelectorAll('.program-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.program-panel').forEach(p => { p.classList.add('hidden'); p.classList.remove('active'); });
        tab.classList.add('active');
        const panel = document.getElementById('panel-' + target);
        panel.classList.remove('hidden');
        requestAnimationFrame(() => panel.classList.add('active'));
      });
    });
  </script>

  <!-- Gallery Section -->
  <section class="gallery-section py-24 bg-gpla-navy overflow-hidden" data-animate>
    <div class="container mx-auto px-6 mb-12">
      <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-2">In The Room</p>
      <h2 class="font-display text-5xl text-white">
        MOMENTS FROM OUR SUMMITS
      </h2>
      <p class="text-white/70 mt-4 max-w-xl">
        700+ leaders. 6 countries. 3 summits. Witness the moments that shaped a movement.
      </p>
    </div>
    
    <!-- Masonry-style grid — 3 cols desktop, 2 tablet, 1 mobile -->
    <div class="gallery-grid px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- 
        GALLERY PLACEHOLDER GRID
        Client to replace gradient boxes with real summit photos.
        Recommended photo dimensions: 
          Large: 800x600px 
          Portrait: 400x600px
