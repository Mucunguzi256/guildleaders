---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Home">
  <Navbar />

  <!-- Hero Section -->
  <!-- VIDEO: drop hero-bg.mp4 into /public/videos/ to activate -->
  <section class="hero relative min-h-screen overflow-hidden flex items-center">
    <!-- VIDEO BACKGROUND — client to provide video file -->
    <div class="hero-video-wrapper absolute inset-0 z-0">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        class="w-full h-full object-cover opacity-30"
        poster="/images/hero-poster.jpg"
      >
        <!-- Client to add: <source src="/videos/hero-bg.mp4" type="video/mp4"> -->
        <!-- Fallback gradient shown until video is provided -->
      </video>
      <!-- Gradient overlay — always visible, darkens video -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#132d82]/95 via-[#132d82]/80 to-[#389a29]/60"></div>
    </div>

    <!-- Hero content sits above video -->
    <div class="relative z-10 max-w-[55%] px-4 md:px-12 py-20 md:py-32">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">Est. Makerere University, Kampala</p>
      <h1 class="font-display text-white text-[48px] md:text-[72px] lg:text-[96px] leading-[0.95] mb-6">
        SHAPING<br />
        EAST AFRICA'S<br />
        NEXT LEADERS.
      </h1>
      <p class="text-white/85 text-lg max-w-[500px] mb-8 leading-relaxed">
        Equipping outgoing Guild Presidents with the knowledge, values, and networks to transform governance across East Africa.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/guildleaders/programs" class="bg-gpla-green text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">
          Our Programs
        </a>
        <a href="/guildleaders/summit" class="border-2 border-white text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold inline-block hover:bg-white hover:text-gpla-navy transition-all">
          View Summit
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="bg-gpla-green px-4 md:px-12 py-10 md:py-16" data-animate>
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 text-center">
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="700" data-suffix="+" class="stat-number">0+</span></div>
        <div class="text-white/85 text-xs md:text-sm">Former Leaders Convened</div>
      </div>
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="4" class="stat-number">0</span></div>
        <div class="text-white/85 text-xs md:text-sm">Flagship Programs</div>
      </div>
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="6" class="stat-number">0</span></div>
        <div class="text-white/85 text-xs md:text-sm">Countries Represented</div>
      </div>
      <div>
        <div class="font-display text-[32px] md:text-[64px] text-white"><span data-count="1" class="stat-number">0</span></div>
        <div class="text-white/85 text-xs md:text-sm">Regional Summit Annually</div>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="px-4 md:px-12 py-16 md:py-24 bg-gpla-light">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="bg-gpla-navy p-8 md:p-12 relative">
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-gpla-green;"></div>
        <p class="text-white text-xl md:text-2xl italic leading-relaxed">"History has been made."</p>
        <cite class="block mt-6 text-gpla-gold text-base not-italic">— Demiano Masesa, Executive Director, GPLA</cite>
      </div>
      <div>
        <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-3">WHO WE ARE</p>
        <h2 class="font-display text-gpla-navy text-[32px] md:text-[48px] leading-tight mb-5">Forging Leaders for a Democratic East Africa</h2>
        <p class="text-gray-600 text-base leading-relaxed mb-6">
          The Guild Presidents Leadership Academy (GPLA) is a prestigious regional institution based at Makerere University, Uganda — the birthplace of African student activism.
        </p>
        <p class="text-gray-600 text-base leading-relaxed mb-6">
          We've convened over 700 youth leaders from 6 countries, hosting sitting Vice Presidents, former Heads of State, EU Ambassadors, and Electoral Commission Chairpersons.
        </p>
        <a href="/guildleaders/about" class="text-gpla-green font-semibold inline-flex items-center gap-2">
          Read Our Full Story →
        </a>
      </div>
    </div>
  </section>

  <!-- Pattern Divider Thin -->
  <div class="h-10 w-full" style="background: linear-gradient(90deg, #389a29 0%, #389a29 16%, #132d82 16%, #132d82 32%, #F5A623 32%, #F5A623 48%, #ffffff 48%, #ffffff 64%, #389a29 64%, #389a29 80%, #132d82 80%, #132d82 100%);"></div>

  <!-- Our Summits — Click Tabs (CrewAI Style) -->
  <section class="summits-tabs-section" data-animate>
    <div class="max-w-7xl mx-auto px-4 md:px-12 py-16 md:py-24">
      <div class="text-center mb-12">
        <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-3">Our Summits</p>
        <h2 class="font-display text-4xl md:text-5xl text-gpla-navy">THREE YEARS. ONE MOVEMENT.</h2>
      </div>
      
      <!-- Tab Navigation -->
      <div class="summit-tabs-nav">
        <button class="summit-tab active" data-tab="2026">
          <span class="tab-year">2026</span>
          <span class="tab-label">3rd Annual</span>
          <span class="tab-badge">UPCOMING</span>
        </button>
        <button class="summit-tab" data-tab="2025">
          <span class="tab-year">2025</span>
          <span class="tab-label">2nd Annual</span>
        </button>
        <button class="summit-tab" data-tab="2024">
          <span class="tab-year">2024</span>
          <span class="tab-label">Inaugural</span>
        </button>
      </div>
      
      <!-- Tab Panels -->
      <div class="summit-panels">
        <div class="summit-panel-tab active" id="panel-2026">
          <div class="panel-content">
            <span class="panel-tag">UPCOMING · 23–24 JULY 2026</span>
            <h3 class="panel-title">3RD ANNUAL EAST AFRICAN GUILD LEADERS' SUMMIT</h3>
            <p class="panel-theme">"Youth Leadership, Production, and Regional Integration: Building a Competitive East Africa in a Changing Global Order"</p>
            <div class="panel-meta">
              <div class="meta-block">
                <span class="meta-label">Chief Guest</span>
                <span class="meta-value">H.E. Yoweri Kaguta Museveni</span>
                <span class="meta-sub">President of Uganda & EAC Chairperson</span>
              </div>
              <div class="meta-block">
                <span class="meta-label">Venue</span>
                <span class="meta-value">Freedom Square</span>
                <span class="meta-sub">Makerere University, Kampala</span>
              </div>
            </div>
            <div class="panel-actions">
              <a href="/guildleaders/summit/2026" class="panel-cta primary">Register Interest →</a>
              <a href="/guildleaders/summit/2026#partner" class="panel-cta ghost">Partner With Us →</a>
            </div>
          </div>
        </div>

        <div class="summit-panel-tab" id="panel-2025">
          <div class="panel-inner">
            <span class="panel-tag" style="color: #F5A623;">2025 · MAKERERE UNIVERSITY</span>
            <h3 class="panel-title">2ND ANNUAL GUILD LEADERS' SUMMIT</h3>
            <p class="panel-theme">"Democratic Governance and People-to-People Integration"</p>
            <div class="panel-meta">
              <div class="meta-block">
                <span class="meta-label">Chief Guest</span>
                <span class="meta-value">HE. Uhuru Kenyatta</span>
                <span class="meta-sub">Former President, Republic of Kenya</span>
              </div>
              <div class="meta-block">
                <span class="meta-label">Attendees</span>
                <span class="meta-value">700+</span>
                <span class="meta-sub">Leaders from across East Africa</span>
              </div>
            </div>
            <div class="panel-actions">
              <a href="/guildleaders/summit/2025" class="panel-cta primary">View Full Report →</a>
            </div>
          </div>
        </div>

        <div class="summit-panel-tab" id="panel-2024">
          <div class="panel-inner">
            <span class="panel-tag" style="color: #F5A623;">APRIL 15, 2024 · MAKERERE UNIVERSITY</span>
            <h3 class="panel-title">INAUGURAL GUILD LEADERS' SUMMIT</h3>
            <p class="panel-theme">"Legacy and Leadership Continuum: The Power of Knowledge and Cross-Generational Learning"</p>
            <div class="panel-meta">
              <div class="meta-block">
                <span class="meta-label">Chief Guest</span>
                <span class="meta-value">HE. Jakaya Mrisho Kikwete</span>
                <span class="meta-sub">Former President, Tanzania · Now Summit Patron</span>
              </div>
              <div class="meta-block">
                <span class="meta-label">Attendees</span>
                <span class="meta-value">700+</span>
                <span class="meta-sub">Historic first convening</span>
              </div>
            </div>
            <div class="panel-actions">
              <a href="/guildleaders/summit/2024" class="panel-cta primary">View Full Report →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pattern Divider -->
  <div class="h-8 w-full" style="background: linear-gradient(90deg, #132d82 0%, #132d82 25%, #389a29 25%, #389a29 50%, #F5A623 50%, #F5A623 75%, #132d82 75%, #132d82 100%);"></div>

  <script>
    // Click-based Summit Tabs (CrewAI Style)
    const initSummitTabs = () => {
      const tabs = document.querySelectorAll('.summit-tab');
      const panels = document.querySelectorAll('.summit-panel-tab');
      
      if (tabs.length === 0) return;
      
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          
          // Update tabs
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          
          // Update panels
          panels.forEach(p => {
            p.classList.remove('active');
            if (p.id === 'panel-' + target) {
              p.classList.add('active');
            }
          });
        });
      });
    };
    initSummitTabs();
  </script>

  <!-- Programs — Click Tabs (CrewAI Style) -->
  <section class="programs-tabs-section" data-animate>
    <div class="max-w-7xl mx-auto px-4 md:px-12 py-16 md:py-24">
      <div class="text-center mb-12">
        <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-3">Our Programs</p>
        <h2 class="font-display text-4xl md:text-5xl text-gpla-navy">BUILD YOUR LEADERSHIP TOOLKIT</h2>
      </div>
      
      <!-- Tab Navigation -->
      <div class="program-tabs-nav">
        <button class="program-tab active" data-tab="tlb">
          <span class="tab-icon">⭐</span>
          <span class="tab-name">TLB</span>
          <span class="tab-sub">Leadership Bootcamp</span>
        </button>
        <button class="program-tab" data-tab="pgil">
          <span class="tab-icon">⚖️</span>
          <span class="tab-name">PGIL</span>
          <span class="tab-sub">Policy Lab</span>
        </button>
        <button class="program-tab" data-tab="herpower">
          <span class="tab-icon">👑</span>
          <span class="tab-name">HERPower</span>
          <span class="tab-sub">Women's Fellowship</span>
        </button>
        <button class="program-tab" data-tab="summit">
          <span class="tab-icon">🎤</span>
          <span class="tab-name">Summit</span>
          <span class="tab-sub">Annual Gathering</span>
        </button>
      </div>
      
      <!-- Tab Panels -->
      <div class="program-panels">
        <div class="program-panel-tab active" id="prog-tlb">
          <div class="panel-content">
            <h3 class="panel-title">Transformational Leadership Bootcamp (TLB)</h3>
            <div class="program-tags">
              <span class="program-tag">5 Days</span>
              <span class="program-tag">Residential</span>
              <span class="program-tag">Intensive</span>
            </div>
            <p class="panel-desc">A rigorous 5-day residential program building essential leadership skills for effective student governance.</p>
            <div class="panel-outcomes">
              <h4 class="outcomes-title">Key Outcomes</h4>
              <ul class="outcomes-list">
                <li>✓ Personal leadership vision creation with actionable steps</li>
                <li>✓ Conflict resolution and strategic planning skills</li>
                <li>✓ Mentorship with public, private, and civil society leaders</li>
              </ul>
            </div>
            <a href="/guildleaders/programs" class="panel-cta primary">Learn More →</a>
          </div>
        </div>

        <div class="program-panel-tab" id="prog-pgil">
          <div class="panel-content">
            <h3 class="panel-title">Policy & Governance Incubation Lab (PGIL)</h3>
            <div class="program-tags">
              <span class="program-tag">8 Weeks</span>
              <span class="program-tag">Hybrid</span>
              <span class="program-tag">Research-Focused</span>
            </div>
            <p class="panel-desc">8-week intensive program building practical policy analysis and advocacy skills for East Africa.</p>
            <div class="panel-outcomes">
              <h4 class="outcomes-title">Key Outcomes</h4>
              <ul class="outcomes-list">
                <li>✓ Public policy analysis and budgeting competency</li>
                <li>✓ Real-time review of national development plans</li>
                <li>✓ Policy briefs and campus-based governance initiatives</li>
              </ul>
            </div>
            <a href="/guildleaders/programs" class="panel-cta primary">Learn More →</a>
          </div>
        </div>

        <div class="program-panel-tab" id="prog-herpower">
          <div class="panel-content">
            <h3 class="panel-title">HERPower Fellowship</h3>
            <div class="program-tags">
              <span class="program-tag">Ongoing</span>
              <span class="program-tag">Mentorship</span>
              <span class="program-tag">Women Only</span>
            </div>
            <p class="panel-desc">Specialized fellowship for young women passionate about political leadership.</p>
            <div class="panel-outcomes">
              <h4 class="outcomes-title">Key Outcomes</h4>
              <ul class="outcomes-list">
                <li>✓ Feminist leadership and political organizing skills</li>
                <li>✓ Mentorship from women leaders in public office</li>
                <li>✓ Network of women committed to democratic leadership</li>
              </ul>
            </div>
            <a href="/guildleaders/programs" class="panel-cta primary">Learn More →</a>
          </div>
        </div>

        <div class="program-panel-tab" id="prog-summit">
          <div class="panel-content">
            <h3 class="panel-title">Guild Leaders' Summit + Guild Voice</h3>
            <div class="program-tags">
              <span class="program-tag">Annual</span>
              <span class="program-tag">2 Days</span>
              <span class="program-tag">700+ Attendees</span>
            </div>
            <p class="panel-desc">Annual flagship gathering bringing together Guild Presidents from across East Africa.</p>
            <div class="panel-outcomes">
              <h4 class="outcomes-title">Key Outcomes</h4>
              <ul class="outcomes-list">
                <li>✓ Pan-East African student leader network</li>
                <li>✓ Cross-border policy dialogue and advocacy</li>
                <li>✓ Regional integration agenda co-creation</li>
              </ul>
            </div>
            <a href="/guildleaders/summit" class="panel-cta primary">Learn More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Click-based Program Tabs (CrewAI Style)
    const initProgramTabs = () => {
      const tabs = document.querySelectorAll('.program-tab');
      const panels = document.querySelectorAll('.program-panel-tab');
      
      if (tabs.length === 0) return;
      
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.dataset.tab;
          
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          
          panels.forEach(p => {
            p.classList.remove('active');
            if (p.id === 'prog-' + target) {
              p.classList.add('active');
            }
          });
        });
      });
    };
    initProgramTabs();
  </script>

  <!-- Gallery Section -->
  <section class="gallery-section py-24 bg-gpla-navy overflow-hidden" data-animate>
    <div class="container mx-auto px-6 mb-12">
      <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-2">In The Room</p>
      <h2 class="font-display text-5xl text-white">
        MOMENTS FROM OUR SUMMITS
      </h2>
      <p class="text-white/70 mt-4 max-w-xl">
        700+ leaders. 6 countries. 3 summits. Witness the moments that shaped a movement.
      </p>
    </div>
    
    <!-- Masonry-style grid — 3 cols desktop, 2 tablet, 1 mobile -->
    <div class="gallery-grid px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-animate>
      <!-- 
        GALLERY PLACEHOLDER GRID
        Client to replace gradient boxes with real summit photos.
        Recommended photo dimensions: 
          Large: 800x600px 
          Portrait: 400x600px
          Square: 500x500px
        Place all gallery images in /public/images/gallery/
        Naming: summit-2024-01.jpg, summit-2025-01.jpg etc.
      -->
      <div class="bg-gradient-to-br from-[#132d82] to-[#389a29] rounded-xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-white/50 text-sm">Summit 2024</span>
      </div>
      <div class="bg-gradient-to-br from-[#389a29] to-[#132d82] rounded-xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-white/50 text-sm">Summit 2025</span>
      </div>
      <div class="bg-gradient-to-br from-[#F5A623] to-[#132d82] rounded-xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-white/50 text-sm">Summit 2026</span>
      </div>
      <div class="bg-gradient-to-br from-[#132d82] to-[#F5A623] rounded-xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-white/50 text-sm">HERPower</span>
      </div>
      <div class="bg-gradient-to-br from-[#389a29] to-[#F5A623] rounded-xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-white/50 text-sm">TLB</span>
      </div>
      <div class="bg-gradient-to-br from-[#F5A623] to-[#389a29] rounded-xl p-8 flex flex-col items-center justify-center min-h-[300px]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-white/50 text-sm">PGIL</span>
      </div>
    </div>

    <div class="text-center mt-12 px-6">
      <a href="/guildleaders/gallery" class="border-2 border-white text-white px-8 py-3 rounded-full font-semibold inline-block hover:bg-white hover:text-gpla-navy transition-all">View Full Gallery →</a>
    </div>

    <!-- Lightbox (hidden by default) -->
    <div id="gallery-lightbox" class="lightbox hidden" role="dialog" aria-modal="true">
      <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
      <img src="" alt="Gallery image" class="lightbox-img max-w-[90vw] max-h-[90vh] object-contain rounded-lg" />
    </div>
  </section>

<!-- Pattern Divider Bold -->
  <div class="h-16 md:h-20 w-full" style="background: linear-gradient(90deg, #389a29 0%, #389a29 12%, #132d82 12%, #132d82 24%, #F5A623 24%, #F5A623 36%, #389a29 36%, #389a29 48%, #ffffff 48%, #ffffff 60%, #132d82 60%, #132d82 72%, #F5A623 72%, #F5A623 84%, #389a29 84%, #389a29 100%);"></div>

  <!-- Partners -->
  <section class="px-4 md:px-12 py-12 md:py-24">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-gpla-navy text-[32px] md:text-[48px] text-center mb-8 md:12">OUR PARTNERS</h2>
      <div class="grid grid-cols-2 md:grid-cols-6 gap-3 md:gap-4">
        {['GIZ', 'EU', 'German Co.', 'ActionAid', 'WFD', 'Akina Mama', 'UYONET', 'UNiFOG', 'NEC', 'CivLegacy', 'Julius Nyerere', 'NDP'].map(partner => (
          <div class="bg-gray-100 p-4 md:p-5 rounded-lg text-center font-display text-sm md:text-lg text-gray-400 hover:bg-gpla-navy hover:text-white transition-all">
            {partner}
          </div>
        ))}
      </div>
      <p class="text-center text-gray-400 text-sm mt-6 md:mt-8">Supported by leading international development organisations</p>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gpla-green px-4 md:px-12 py-12 md:py-20 text-center">
    <h2 class="font-display text-white text-[36px] md:text-[72px] mb-4">ARE YOU A GUILD LEADER?</h2>
    <p class="text-white/85 text-lg md:text-xl mb-6 md:mb-8">Join the movement. Apply for the next cohort.</p>
    <a href="/guildleaders/contact" class="bg-white text-gpla-navy px-8 md:px-10 py-4 md:py-5 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">
      Apply Now
    </a>
  </section>

  <script>
    const animateStats = () => {
      const stats = document.querySelectorAll('[data-count]');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !entry.target.dataset.animated) {
            entry.target.dataset.animated = 'true';
            const target = parseInt(entry.target.dataset.count);
            const suffix = entry.target.dataset.suffix || '';
            const duration = 2000;
            const step = target / (duration / 16);
            let current = 0;
            const timer = setInterval(() => {
              current += step;
              if (current >= target) {
                current = target;
                clearInterval(timer);
              }
              entry.target.textContent = Math.floor(current) + suffix;
            }, 16);
          }
        });
      }, { threshold: 0.3 });
      stats.forEach(stat => observer.observe(stat));
    };
    animateStats();

    const animateOnScroll = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.dataset.delay || 0;
          setTimeout(() => {
            entry.target.classList.add('animate-in');
          }, delay);
          animateOnScroll.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate]')
      .forEach(el => animateOnScroll.observe(el));

    // Gallery Lightbox
    const initLightbox = () => {
      const lightbox = document.getElementById('gallery-lightbox');
      const lightboxImg = lightbox?.querySelector('.lightbox-img');
      const closeBtn = lightbox?.querySelector('.lightbox-close');
      const galleryItems = document.querySelectorAll('.gallery-item');
      
      if (!lightbox || !lightboxImg || galleryItems.length === 0) return;
      
      galleryItems.forEach(item => {
        item.addEventListener('click', () => {
          const img = item.querySelector('img');
          if (img) {
            lightboxImg.src = img.src;
            lightboxImg.alt = img.alt || 'Gallery image';
            lightbox.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
          }
        });
      });
      
      const closeLightbox = () => {
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
      };
      
      closeBtn?.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
      });
    };
    initLightbox();
  </script>

  <Footer />
</Base>