---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Summit 2026" description="3rd Annual East African Guild Leaders' Summit - July 23-24, 2026">
  <Navbar />
  
  <!-- Hero Section with Video Background -->
  <section class="hero relative min-h-[70vh] md:min-h-[80vh] overflow-hidden flex items-center">
    <!-- VIDEO BACKGROUND — client to provide video file -->
    <div class="hero-video-wrapper absolute inset-0 z-0">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        class="w-full h-full object-cover opacity-30"
        poster="/images/hero-poster.jpg"
      >
        <!-- Client to add: <source src="/videos/hero-bg.mp4" type="video/mp4"> -->
      </video>
      <div class="absolute inset-0 bg-gradient-to-r from-[#132d82]/95 via-[#132d82]/80 to-[#389a29]/60"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 md:px-12 py-20 md:py-32 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <p class="bg-gpla-gold text-gpla-navy text-sm font-semibold uppercase tracking-widest px-4 py-2 rounded-full inline-block mb-6">UPCOMING · 23–24 JULY 2026</p>
          <h1 class="font-display text-white text-[42px] md:text-[56px] lg:text-[72px] leading-[0.95] mb-6">
            <span class="block" data-animate>3RD ANNUAL</span>
            <span class="block" data-animate data-delay="100">EAST AFRICAN</span>
            <span class="block" data-animate data-delay="200">GUILD LEADERS'</span>
            <span class="block text-gpla-green" data-animate data-delay="300">SUMMIT</span>
          </h1>
          <p class="text-white/80 text-lg md:text-xl italic mb-6 font-body">
            Youth Leadership, Production, and Regional Integration: Building a Competitive East Africa in a Changing Global Order
          </p>
          <div class="flex flex-wrap gap-4 mb-6">
            <a href="#register" class="bg-gpla-green text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">
              Register Interest
            </a>
            <a href="#partner" class="border-2 border-white text-white px-6 md:px-8 py-3 md:py-4 rounded-full font-semibold inline-block hover:bg-white hover:text-gpla-navy transition-all">
              Partner With Us
            </a>
          </div>
          <p class="text-gpla-gold text-sm font-mono">#TheGuildLeadersSummit2026 · #GPLASummit</p>
        </div>
        <div class="hidden lg:block text-center relative">
          <div class="font-display text-[200px] text-gpla-gold/20 leading-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">2026</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Countdown Timer - TASK 7 -->
  <section class="px-4 md:px-12 py-12 bg-gpla-navy">
    <div class="max-w-4xl mx-auto">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-8 text-center">COUNTDOWN TO THE SUMMIT</p>
      <!-- 2x2 grid on mobile <400px, 4-col on larger -->
      <div class="countdown-grid">
        <div class="countdown-unit">
          <span id="count-days" class="countdown-number">00</span>
          <span class="countdown-label">Days</span>
        </div>
        <div class="countdown-unit">
          <span id="count-hours" class="countdown-number">00</span>
          <span class="countdown-label">Hours</span>
        </div>
        <div class="countdown-unit">
          <span id="count-mins" class="countdown-number">00</span>
          <span class="countdown-label">Minutes</span>
        </div>
        <div class="countdown-unit">
          <span id="count-secs" class="countdown-number">00</span>
          <span class="countdown-label">Seconds</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Summit Details -->
  <section class="px-4 md:px-12 py-16 md:py-24 bg-[var(--bg-section-alt)]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16">
      <div>
        <h2 class="font-display text-gpla-navy text-[32px] md:text-[48px] mb-8">EVENT DETAILS</h2>
        <div class="space-y-6">
          <div class="border-l-4 border-gpla-green pl-4">
            <h4 class="font-semibold text-gpla-navy text-lg">Date</h4>
            <p class="text-[var(--text-muted)]">23rd – 24th July 2026</p>
          </div>
          <div class="border-l-4 border-gpla-green pl-4">
            <h4 class="font-semibold text-gpla-navy text-lg">Venue</h4>
            <p class="text-[var(--text-muted)]">Freedom Square, Makerere University, Kampala</p>
          </div>
          <div class="border-l-4 border-gpla-green pl-4">
            <h4 class="font-semibold text-gpla-navy text-lg">Chief Guest</h4>
            <p class="text-[var(--text-muted)]">H.E. Yoweri Kaguta Museveni<br/>President of the Republic of Uganda & Chairperson of the EAC</p>
          </div>
          <div class="border-l-4 border-gpla-green pl-4">
            <h4 class="font-semibold text-gpla-navy text-lg">Partners</h4>
            <div class="flex gap-4 mt-2">
              <div class="bg-gpla-navy text-white px-4 py-2 rounded font-display text-sm">IGDS</div>
              <div class="bg-gpla-navy text-white px-4 py-2 rounded font-display text-sm">UNiFOG</div>
            </div>
          </div>
        </div>
      </div>
      <div class="flex items-center">
        <div class="bg-gpla-navy p-8 md:p-12 rounded-xl w-full">
          <p class="text-gpla-gold font-display text-2xl md:text-3xl italic leading-relaxed">
            "Youth Leadership, Production, and Regional Integration: Building a Competitive East Africa in a Changing Global Order"
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Focus Areas -->
  <section class="px-4 md:px-12 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-gpla-navy text-[32px] md:text-[48px] text-center mb-12">FOCUS AREAS</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="focus-card bg-[var(--bg-section-alt)] p-6 md:p-8 rounded-xl hover:shadow-xl transition-all" data-animate data-delay="0">
          <span class="text-gpla-green font-display text-3xl">01</span>
          <h4 class="font-semibold text-gpla-navy text-lg mt-3">Political and Economic Integration</h4>
        </div>
        <div class="focus-card bg-[var(--bg-section-alt)] p-6 md:p-8 rounded-xl hover:shadow-xl transition-all" data-animate data-delay="100">
          <span class="text-gpla-green font-display text-3xl">02</span>
          <h4 class="font-semibold text-gpla-navy text-lg mt-3">Youth, Production and Industrial Transformation</h4>
        </div>
        <div class="focus-card bg-[var(--bg-section-alt)] p-6 md:p-8 rounded-xl hover:shadow-xl transition-all" data-animate data-delay="200">
          <span class="text-gpla-green font-display text-3xl">03</span>
          <h4 class="font-semibold text-gpla-navy text-lg mt-3">Regional Markets, Trade and Economic Opportunities</h4>
        </div>
        <div class="focus-card bg-[var(--bg-section-alt)] p-6 md:p-8 rounded-xl hover:shadow-xl transition-all" data-animate data-delay="300">
          <span class="text-gpla-green font-display text-3xl">04</span>
          <h4 class="font-semibold text-gpla-navy text-lg mt-3">Sports Diplomacy and Regional Integration (AFCON 2027)</h4>
        </div>
        <div class="focus-card bg-[var(--bg-section-alt)] p-6 md:p-8 rounded-xl hover:shadow-xl transition-all" data-animate data-delay="400">
          <span class="text-gpla-green font-display text-3xl">05</span>
          <h4 class="font-semibold text-gpla-navy text-lg mt-3">Technology, Innovation and the Digital Economy</h4>
        </div>
        <div class="focus-card bg-[var(--bg-section-alt)] p-6 md:p-8 rounded-xl hover:shadow-xl transition-all" data-animate data-delay="500">
          <span class="text-gpla-green font-display text-3xl">06</span>
          <h4 class="font-semibold text-gpla-navy text-lg mt-3">Education, Mobility and Knowledge Integration</h4>
        </div>
      </div>
    </div>
  </section>

  <!-- Speaker Applications CTA -->
  <section class="cta-speak bg-gpla-gold py-20 px-4 md:px-12">
    <div class="container mx-auto text-center">
      <h2 class="font-display text-gpla-navy text-[40px] md:text-[56px] mb-4">
        APPLY TO SPEAK
      </h2>
      <p class="text-gpla-navy/80 text-lg mb-8 max-w-2xl mx-auto">
        Are you a policymaker, entrepreneur, academic, or regional leader with a message for East Africa's next generation? Apply to address the 3rd Annual East African Guild Leaders' Summit.
      </p>
      <a href="https://formspree.io/f/SPEAKER_FORM_ID" class="bg-gpla-navy text-white px-8 py-4 rounded-full font-semibold inline-block hover:shadow-xl hover:-translate-y-0.5 transition-all">
        Apply to Speak →
      </a>
    </div>
  </section>

  <!-- Partner Applications CTA -->
  <section id="partner" class="cta-partner bg-gpla-navy py-20 px-4 md:px-12">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-center">
        <div>
          <h2 class="font-display text-white text-[40px] md:text-[56px] mb-6">
            PARTNER WITH US
          </h2>
          <p class="text-white/70 text-lg mb-6">
            Align your organisation with East Africa's premier youth leadership platform. The 2026 Summit will convene heads of state, regional institutions, and 700+ student leaders from across the EAC.
          </p>
          <ul class="partner-benefits space-y-3 text-white/80">
            <li class="flex items-center gap-3"><span class="text-gpla-green text-xl">✓</span> Brand visibility across 6 East African countries</li>
            <li class="flex items-center gap-3"><span class="text-gpla-green text-xl">✓</span> Direct access to emerging youth leaders</li>
            <li class="flex items-center gap-3"><span class="text-gpla-green text-xl">✓</span> Co-branding on Summit materials and reports</li>
            <li class="flex items-center gap-3"><span class="text-gpla-green text-xl">✓</span> Panel and speaking opportunities</li>
          </ul>
        </div>
        <div class="partner-form bg-white/5 p-6 md:p-8 rounded-xl">
          <h3 class="text-white font-display text-2xl mb-6">
            APPLY TO PARTNER
          </h3>
          <form method="POST" action="https://formspree.io/f/PARTNER_FORM_ID">
            <input type="hidden" name="form-name" value="summit-2026-partner" />
            <div class="space-y-4">
              <input type="text" name="organisation" placeholder="Organisation Name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/50 focus:outline-none focus:border-gpla-green" />
              <input type="text" name="contact_person" placeholder="Contact Person" required class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/50 focus:outline-none focus:border-gpla-green" />
              <input type="email" name="email" placeholder="Email Address" required class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/50 focus:outline-none focus:border-gpla-green" />
              <select name="partnership_type" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white focus:outline-none focus:border-gpla-green">
                <option value="" class="text-gpla-navy">Select Partnership Type</option>
                <option value="Lead Partner" class="text-gpla-navy">Lead Partner</option>
                <option value="Gold Partner" class="text-gpla-navy">Gold Partner</option>
                <option value="Silver Partner" class="text-gpla-navy">Silver Partner</option>
                <option value="Media Partner" class="text-gpla-navy">Media Partner</option>
                <option value="Academic Partner" class="text-gpla-navy">Academic Partner</option>
              </select>
              <textarea name="message" placeholder="Tell us about your organisation and interest in partnering" rows="4" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-white/50 focus:outline-none focus:border-gpla-green"></textarea>
              <button type="submit" class="w-full bg-gpla-green text-white px-8 py-4 rounded-full font-semibold hover:shadow-xl hover:-translate-y-0.5 transition-all">
                Submit Partnership Application →
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Save the Date / Register Interest -->
  <section id="register" class="bg-gpla-green px-4 md:px-12 py-16 md:py-24 text-center">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-white text-[40px] md:text-[56px] mb-4">SAVE THE DATE</h2>
      <p class="text-white text-lg md:text-xl italic mb-8 max-w-[600px] mx-auto">
        "The Future of East Africa Will Not Be Inherited. It Will Be Built. And the Builders Are Here."
      </p>
      <form action="https://formspree.io/f/REGISTER_FORM_ID" method="POST" class="max-w-md mx-auto bg-white p-8 rounded-xl">
        <input type="hidden" name="_next" value="/guildleaders/summit/2026?registered=true" />
        <div class="space-y-4">
          <div>
            <label for="name" class="block text-gray-600 text-sm font-medium mb-2">Full Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-gray-600 text-sm font-medium mb-2">Email Address</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent" />
          </div>
          <div>
            <label for="institution" class="block text-gray-600 text-sm font-medium mb-2">Institution / Organization</label>
            <input type="text" id="institution" name="institution" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent" />
          </div>
          <div>
            <label for="country" class="block text-gray-600 text-sm font-medium mb-2">Country</label>
            <select id="country" name="country" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent">
              <option value="">Select Country</option>
              <option value="Uganda">Uganda</option>
              <option value="Kenya">Kenya</option>
              <option value="Tanzania">Tanzania</option>
              <option value="Rwanda">Rwanda</option>
              <option value="Burundi">Burundi</option>
              <option value="South Sudan">South Sudan</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <button type="submit" class="w-full bg-gpla-navy text-white px-8 py-4 rounded-full font-semibold hover:shadow-xl hover:-translate-y-0.5 transition-all">
            Register Interest
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- Thank You (shown when registered) -->
  <section id="thank-you" class="hidden px-4 md:px-12 py-12 md:py-20 bg-[var(--bg-section-alt)] text-center">
    <div class="text-6xl mb-4">🎉</div>
    <h2 class="font-display text-gpla-navy text-[40px] mb-4">You're Registered!</h2>
    <p class="text-[var(--text-muted)] text-lg">We'll be in touch with more details about the 2026 Summit.</p>
  </section>

  <Footer />
</Base>

<script>
  // Countdown to July 23, 2026 08:00 EAT (UTC+3)
  const target = new Date('2026-07-23T05:00:00Z');
  
  function updateCountdown() {
    const now = new Date();
    const diff = target - now;
    
    if (diff <= 0) {
      document.querySelector('.countdown')!.innerHTML = '<p class="text-gpla-gold text-2xl font-display">THE SUMMIT IS LIVE</p>';
      return;
    }
    
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const mins = Math.floor((diff % 3600000) / 60000);
    const secs = Math.floor((diff % 60000) / 1000);
    
    const units = [
      { id: 'count-days', val: days },
      { id: 'count-hours', val: hours },
      { id: 'count-mins', val: mins },
      { id: 'count-secs', val: secs }
    ];
    
    units.forEach(unit => {
      const el = document.getElementById(unit.id);
      if (el) {
        const newVal = String(unit.val).padStart(2, '0');
        if (el.textContent !== newVal) {
          el.classList.add('flip');
          setTimeout(() => { 
            el.textContent = newVal;
            el.classList.remove('flip');
          }, 150);
        }
      }
    });
  }
  
  setInterval(updateCountdown, 1000);
  updateCountdown();

  // Scroll animations
  const animateOnScroll = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const delay = entry.target.dataset.delay || 0;
        setTimeout(() => {
          entry.target.classList.add('animate-in');
        }, parseInt(delay));
        animateOnScroll.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('[data-animate]').forEach(el => animateOnScroll.observe(el));

  // Show thank you if registered
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('registered') === 'true') {
    document.getElementById('thank-you')?.classList.remove('hidden');
  }
</script>