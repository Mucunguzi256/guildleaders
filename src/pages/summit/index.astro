---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const summits = [
  { year: '2024', title: 'Guild Leaders Annual Summit', theme: 'Legacy and Leadership Continuum', date: 'April 15, 2024', attendees: '700+', status: 'past' },
  { year: '2025', title: 'Guild Leaders Annual Summit', theme: 'Democratic Transformation', date: 'April 2025', attendees: '700+', status: 'past' },
  { year: '2026', title: 'Guild Leaders Annual Summit', theme: 'East Africa Youth Leadership', date: 'July 2026', attendees: 'Upcoming', status: 'upcoming' },
];
---

<Base title="Summit" description="The Guild Leaders' Annual Summit - East Africa's premier youth leadership gathering.">
  <Navbar />
  
  <!-- Hero -->
  <section class="min-h-[60vh] bg-gpla-navy px-12 pt-32 pb-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[45%] h-full bg-gpla-green" style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">SUMMIT</p>
      <h1 class="font-display text-white text-[72px] leading-tight">
        GUILD LEADERS'<br />
        ANNUAL SUMMIT
      </h1>
      <p class="text-white/85 text-xl mt-6 max-w-[600px]">
        "Legacy and Leadership Continuum: The Power of Knowledge and Cross-Generational Learning"
      </p>
    </div>
  </section>

  <!-- About the Summit -->
  <section class="px-12 py-24">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-gpla-navy text-[48px] mb-8">ABOUT THE SUMMIT</h2>
      <p class="text-gray-600 text-lg leading-relaxed max-w-[800px]">
        The Guild Leaders' Annual Summit is GPLA's flagship event, bringing together over 700 student leaders from across East Africa. Held annually at Makerere University, the summit serves as a platform for knowledge sharing, networking, and capacity building for the next generation of African leaders.
      </p>
    </div>
  </section>

  <!-- Summit Cards -->
  <section class="px-12 py-24 bg-gpla-light">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- 2024 -->
        <div class="bg-gpla-navy p-10 rounded-xl">
          <div class="font-display text-[80px] text-white/30 leading-none">2024</div>
          <p class="text-gpla-gold text-sm font-semibold uppercase tracking-widest mt-[-20px] mb-4">Past Summit</p>
          <h3 class="font-display text-[32px] text-white mb-3">Guild Leaders' Summit 2024</h3>
          <p class="text-white/70 text-sm mb-4">April 15, 2024 · 700+ Attendees</p>
          <p class="text-white/85 text-base mb-6">"Legacy and Leadership Continuum"</p>
          <a href="/summit/2024" class="text-white font-semibold inline-flex items-center gap-2">
            View Full Report →
          </a>
        </div>

        <!-- 2025 -->
        <div class="bg-gpla-navy p-10 rounded-xl">
          <div class="font-display text-[80px] text-white/30 leading-none">2025</div>
          <p class="text-gpla-gold text-sm font-semibold uppercase tracking-widest mt-[-20px] mb-4">Past Summit</p>
          <h3 class="font-display text-[32px] text-white mb-3">Guild Leaders' Summit 2025</h3>
          <p class="text-white/70 text-sm mb-4">April 2025 · 700+ Attendees</p>
          <p class="text-white/85 text-base mb-6">"Democratic Transformation"</p>
          <a href="/summit/2025" class="text-white font-semibold inline-flex items-center gap-2">
            View Full Report →
          </a>
        </div>

        <!-- 2026 -->
        <div class="bg-gpla-navy p-10 rounded-xl border-2 border-gpla-gold">
          <div class="font-display text-[80px] text-gpla-gold/30 leading-none">2026</div>
          <p class="bg-gpla-gold text-gpla-navy text-sm font-semibold uppercase tracking-widest mt-[-20px] mb-4 px-3 py-1 inline-block rounded-full">UPCOMING</p>
          <h3 class="font-display text-[32px] text-white mb-3">Guild Leaders' Summit 2026</h3>
          <p class="text-white/70 text-sm mb-4">July 2026 · Kampala, Uganda</p>
          <p class="text-white/85 text-base mb-6">"East Africa's Premier Youth Leadership Convening"</p>
          <a href="/summit/2026" class="text-gpla-gold font-semibold inline-flex items-center gap-2">
            Register Interest →
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>