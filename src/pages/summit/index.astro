---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Base title="Summit" description="The Guild Leaders' Annual Summit - East Africa's premier youth leadership gathering.">
  <Navbar />
  
  <!-- Hero -->
  <section class="min-h-[50vh] md:min-h-[60vh] bg-gpla-navy px-4 md:px-12 pt-28 md:pt-32 pb-16 md:pb-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[45%] h-full bg-gpla-green" style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">SUMMIT</p>
      <h1 class="font-display text-white text-[36px] md:text-[56px] md:text-[72px] leading-tight">
        GUILD LEADERS'<br />ANNUAL SUMMIT
      </h1>
      <p class="text-white/85 text-lg md:text-xl mt-4 md:mt-6 max-w-[600px]">
        From 700 student leaders in 2024 to a growing East African regional movement — the Guild Leaders' Summit is the continent's premier youth leadership convening.
      </p>
    </div>
  </section>

  <!-- Summit Cards -->
  <section class="px-4 md:px-12 py-12 md:py-24 bg-gpla-light">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <!-- 2024 -->
        <div class="bg-gpla-navy p-8 md:p-10 rounded-xl">
          <div class="font-display text-[64px] md:text-[80px] text-white/30 leading-none">2024</div>
          <p class="bg-gray-500 text-white text-xs font-semibold uppercase tracking-widest mt-[-20px] mb-4 px-3 py-1 inline-block rounded-full w-fit">Past Summit</p>
          <h3 class="font-display text-[24px] md:text-[28px] text-white mb-3">Guild Leaders' Summit 2024</h3>
          <p class="text-white/70 text-sm mb-2">"Legacy and Leadership Continuum"</p>
          <p class="text-white/70 text-xs mb-4">April 15, 2024 · Makerere University · 700+ Attendees</p>
          <p class="text-gpla-gold text-sm font-semibold mb-4">Chief Guest: HE. Jakaya Mrisho Kikwete<br/>Former President, Tanzania</p>
          <a href="/guildleaders/summit/2024" class="text-white font-semibold text-sm inline-flex items-center gap-2">View Full Report →</a>
        </div>
        <!-- 2025 -->
        <div class="bg-gpla-navy p-8 md:p-10 rounded-xl">
          <div class="font-display text-[64px] md:text-[80px] text-white/30 leading-none">2025</div>
          <p class="bg-gray-500 text-white text-xs font-semibold uppercase tracking-widest mt-[-20px] mb-4 px-3 py-1 inline-block rounded-full w-fit">Past Summit</p>
          <h3 class="font-display text-[24px] md:text-[28px] text-white mb-3">Guild Leaders' Summit 2025</h3>
          <p class="text-white/70 text-sm mb-2">"Democratic Governance and People-to-People Integration"</p>
          <p class="text-white/70 text-xs mb-4">2025 · Makerere University · 700+ Attendees</p>
          <p class="text-gpla-gold text-sm font-semibold mb-4">Chief Guest: HE. Uhuru Kenyatta<br/>Former President, Kenya</p>
          <a href="/guildleaders/summit/2025" class="text-white font-semibold text-sm inline-flex items-center gap-2">View Full Report →</a>
        </div>
        <!-- 2026 -->
        <div class="bg-gpla-navy p-8 md:p-10 rounded-xl border-2 border-gpla-gold">
          <div class="font-display text-[64px] md:text-[80px] text-gpla-gold/30 leading-none">2026</div>
          <p class="bg-gpla-gold text-gpla-navy text-xs font-semibold uppercase tracking-widest mt-[-20px] mb-4 px-3 py-1 inline-block rounded-full w-fit">UPCOMING · 23–24 JULY 2026</p>
          <h3 class="font-display text-[24px] md:text-[28px] text-white mb-3">3rd Annual East African Guild Leaders' Summit</h3>
          <p class="text-white/70 text-sm mb-2">"Youth Leadership, Production, and Regional Integration"</p>
          <p class="text-white/70 text-xs mb-4">23–24 July 2026 · Makerere University, Kampala</p>
          <p class="text-gpla-gold text-sm font-semibold mb-4">Chief Guest: H.E. Yoweri Kaguta Museveni<br/>President of Uganda & EAC Chairperson</p>
          <a href="/guildleaders/summit/2026" class="text-gpla-gold font-semibold text-sm inline-flex items-center gap-2">Register Interest →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>