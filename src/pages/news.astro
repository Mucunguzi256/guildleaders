---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="News" description="Latest news and updates from the Guild Presidents Leadership Academy.">
  <Navbar />
  
  <!-- Hero -->
  <section class="min-h-[50vh] md:min-h-[60vh] bg-gpla-navy px-4 md:px-12 pt-28 md:pt-32 pb-16 md:pb-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[45%] h-full bg-gpla-green" style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">NEWS</p>
      <h1 class="font-display text-white text-[36px] md:text-[56px] md:text-[72px] leading-tight">
        Latest Updates<br />From GPLA
      </h1>
    </div>
  </section>

  <!-- News Grid -->
  <section class="px-4 md:px-12 py-12 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <article class="bg-gpla-light rounded-xl overflow-hidden">
          <div class="h-40 md:h-48 bg-gpla-navy"></div>
          <div class="p-6 md:p-8">
            <p class="text-gpla-green text-sm font-semibold mb-2">January 15, 2026</p>
            <h3 class="font-display text-lg md:text-xl text-gpla-navy mb-3">2026 Summit Dates Announced</h3>
            <p class="text-gray-600 text-sm mb-4">Mark your calendars for the biggest gathering of East African youth leaders.</p>
            <span class="text-gpla-green font-semibold text-sm">Read More →</span>
          </div>
        </article>
        <article class="bg-gpla-light rounded-xl overflow-hidden">
          <div class="h-40 md:h-48 bg-gpla-navy"></div>
          <div class="p-6 md:p-8">
            <p class="text-gpla-green text-sm font-semibold mb-2">December 10, 2025</p>
            <h3 class="font-display text-lg md:text-xl text-gpla-navy mb-3">HERPower Fellowship Opens</h3>
            <p class="text-gray-600 text-sm mb-4">Applications now open for our flagship women's leadership program.</p>
            <span class="text-gpla-green font-semibold text-sm">Read More →</span>
          </div>
        </article>
        <article class="bg-gpla-light rounded-xl overflow-hidden">
          <div class="h-40 md:h-48 bg-gpla-navy"></div>
          <div class="p-6 md:p-8">
            <p class="text-gpla-green text-sm font-semibold mb-2">November 22, 2025</p>
            <h3 class="font-display text-lg md:text-xl text-gpla-navy mb-3">Partnership with GIZ</h3>
            <p class="text-gray-600 text-sm mb-4">New partnership to expand our leadership programs regionally.</p>
            <span class="text-gpla-green font-semibold text-sm">Read More →</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <Footer />
</Base>