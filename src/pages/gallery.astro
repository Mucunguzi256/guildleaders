---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Gallery" description="View moments from the Guild Leaders' Summits across East Africa.">
  <Navbar />

  <!-- Hero -->
  <section class="min-h-[50vh] bg-gpla-navy px-4 md:px-12 py-32 relative overflow-hidden flex items-center">
    <div class="absolute inset-0 bg-gradient-to-r from-[#132d82]/95 via-[#132d82]/80 to-[#389a29]/60"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-gpla-green font-semibold uppercase tracking-widest text-sm mb-4">GPLA Gallery</p>
      <h1 class="font-display text-white text-5xl md:text-7xl lg:text-8xl mb-6">
        OUR GALLERY
      </h1>
      <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto">
        700+ leaders. 6 countries. 3 summits. Witness the moments that shaped a movement.
      </p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="px-4 md:px-12 py-16 md:py-24 bg-[var(--bg-section-alt)]">
    <div class="max-w-6xl mx-auto">
      <div class="gallery-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- 
          GALLERY PLACEHOLDER GRID
          Client to replace gradient boxes with real summit photos.
          Recommended photo dimensions: 
            Large: 800x600px 
            Portrait: 400x600px
            Square: 500x500px
          Place all gallery images in /public/images/gallery/
          Naming: summit-2024-01.jpg, summit-2025-01.jpg etc.
        -->
        
        <!-- 2024 Summits -->
        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#132d82] to-[#389a29]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Summit 2024</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-green text-xs font-bold uppercase tracking-widest">Inaugural Summit</span>
              <p class="text-white font-display text-xl mt-1">April 15, 2024</p>
              <p class="text-white/70 text-sm">Makerere University</p>
            </div>
          </div>
        </div>

        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#389a29] to-[#132d82]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Opening Ceremony</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-green text-xs font-bold uppercase tracking-widest">Inaugural Summit</span>
              <p class="text-white font-display text-xl mt-1">700+ Attendees</p>
            </div>
          </div>
        </div>

        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#F5A623] to-[#132d82]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Keynote Address</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-gold text-xs font-bold uppercase tracking-widest">HE. Jakaya Mrisho Kikwete</span>
              <p class="text-white font-display text-xl mt-1">Former President, Tanzania</p>
            </div>
          </div>
        </div>

        <!-- 2025 Summits -->
        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#132d82] to-[#F5A623]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Summit 2025</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-green text-xs font-bold uppercase tracking-widest">2nd Annual Summit</span>
              <p class="text-white font-display text-xl mt-1">2025</p>
            </div>
          </div>
        </div>

        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#389a29] to-[#F5A623]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Panel Session</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-green text-xs font-bold uppercase tracking-widest">Democratic Governance</span>
              <p class="text-white font-display text-xl mt-1">Policy Discussion</p>
            </div>
          </div>
        </div>

        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#F5A623] to-[#389a29]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Networking</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-gold text-xs font-bold uppercase tracking-widest">HE. Uhuru Kenyatta</span>
              <p class="text-white font-display text-xl mt-1">Chief Guest</p>
            </div>
          </div>
        </div>

        <!-- 2026 -->
        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#132d82] to-[#389a29]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Summit 2026</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-gold text-xs font-bold uppercase tracking-widest">3rd Annual Summit</span>
              <p class="text-white font-display text-xl mt-1">Coming July 23–24, 2026</p>
            </div>
          </div>
        </div>

        <!-- HERPower -->
        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#389a29] to-[#132d82]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">HERPower</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-gold text-xs font-bold uppercase tracking-widest">Women's Leadership</span>
              <p class="text-white font-display text-xl mt-1">Empowering the next generation</p>
            </div>
          </div>
        </div>

        <!-- TLB -->
        <div class="gallery-item group relative rounded-xl overflow-hidden min-h-[300px] bg-gradient-to-br from-[#F5A623] to-[#389a29]">
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white/30 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-white/50 text-sm">Leadership Bootcamp</span>
          </div>
          <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
            <div>
              <span class="text-gpla-green text-xs font-bold uppercase tracking-widest">Transformational</span>
              <p class="text-white font-display text-xl mt-1">5-Day Intensive Program</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script>
  const animateOnScroll = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
        animateOnScroll.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.gallery-item').forEach((el, i) => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(20px)';
    (el as HTMLElement).style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    (el as HTMLElement).style.transitionDelay = `${i * 0.05}s`;
    animateOnScroll.observe(el);
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });
</script>