---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Contact" description="Get in touch with the Guild Presidents Leadership Academy.">
  <Navbar />
  
  <!-- Hero -->
  <section class="min-h-[60vh] bg-gpla-navy px-12 pt-32 pb-24 relative overflow-hidden">
    <div class="absolute bottom-0 right-0 w-[45%] h-full bg-gpla-green" style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <p class="text-gpla-green text-sm font-semibold uppercase tracking-widest mb-4">CONTACT</p>
      <h1 class="font-display text-white text-[72px] leading-tight">
        Get In<br />Touch
      </h1>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="px-12 py-24">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display text-gpla-navy text-[40px] mb-6">Send Us a Message</h2>
        <!-- TODO: replace with Formspree form ID from formspree.io -->
        <form action="https://formspree.io/f/FORM_ID" method="POST" class="space-y-6">
          <div>
            <label for="name" class="block text-gray-600 text-sm font-medium mb-2">Full Name</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-gray-600 text-sm font-medium mb-2">Email Address</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent" />
          </div>
          <div>
            <label for="subject" class="block text-gray-600 text-sm font-medium mb-2">Subject</label>
            <select id="subject" name="subject"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent">
              <option value="">Select a subject</option>
              <option value="application">Program Application</option>
              <option value="partnership">Partnership Inquiry</option>
              <option value="media">Media & Press</option>
              <option value="general">General Inquiry</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-gray-600 text-sm font-medium mb-2">Message</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gpla-green focus:border-transparent"></textarea>
          </div>
          <button type="submit" class="w-full bg-gpla-green text-white px-8 py-4 rounded-full font-semibold hover:shadow-xl hover:-translate-y-0.5 transition-all">
            Send Message
          </button>
        </form>
      </div>
      <div>
        <h2 class="font-display text-gpla-navy text-[40px] mb-6">Contact Information</h2>
        <div class="space-y-6">
          <div>
            <h3 class="font-display text-xl text-gpla-navy mb-2">Address</h3>
            <p class="text-gray-600">
              Plot 158 Observatory Hill<br />
              Makerere University, Kampala<br />
              Uganda
            </p>
          </div>
          <div>
            <h3 class="font-display text-xl text-gpla-navy mb-2">Email</h3>
            <p class="text-gray-600">info@guildleaders.academy</p>
          </div>
          <div>
            <h3 class="font-display text-xl text-gpla-navy mb-2">Phone</h3>
            <p class="text-gray-600">+256 779 011 22</p>
          </div>
          <div>
            <h3 class="font-display text-xl text-gpla-navy mb-2">Office Hours</h3>
            <p class="text-gray-600">
              Monday - Friday: 8:00 AM - 5:00 PM<br />
              Saturday: 9:00 AM - 1:00 PM
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>