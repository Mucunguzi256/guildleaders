---
const base = '/guildleaders';
---

<footer class="bg-gpla-navy text-white pt-12 md:pt-16 pb-8">
  <div class="max-w-6xl mx-auto px-4 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-12">
      <div>
        <img src="/guildleaders/images/gpla-logo-new.png" alt="Guild Leaders" class="h-16 md:h-20 w-auto object-contain mb-4" style="width: auto; height: 80px; object-fit: contain; image-rendering: -webkit-optimize-contrast;" />
        <p class="text-white/80 text-sm leading-7">Empowering ethical youth leaders for democratic transformation in East Africa.</p>
      </div>
      <div>
        <h5 class="font-display text-lg md:text-xl mb-4 md:mb-5">Quick Links</h5>
        <div class="flex flex-col gap-2 md:gap-3">
          <a href="/guildleaders/about" class="text-white/80 text-sm hover:text-gpla-green transition-colors">About</a>
          <a href="/guildleaders/programs" class="text-white/80 text-sm hover:text-gpla-green transition-colors">Programs</a>
          <a href="/guildleaders/summit" class="text-white/80 text-sm hover:text-gpla-green transition-colors">Summit</a>
          <a href="/guildleaders/news" class="text-white/80 text-sm hover:text-gpla-green transition-colors">News</a>
          <a href="/guildleaders/contact" class="text-white/80 text-sm hover:text-gpla-green transition-colors">Contact</a>
        </div>
      </div>
      <div>
        <h5 class="font-display text-lg md:text-xl mb-4 md:mb-5">Contact</h5>
        <p class="text-white/80 text-sm leading-7">
          Plot 158 Observatory Hill<br />
          Makerere University, Kampala
        </p>
        <p class="text-white/80 text-sm mt-3">info@guildleaders.academy</p>
        <p class="text-white/80 text-sm">+256 779 011 22</p>
      </div>
    </div>
    <div class="border-t border-white/10 pt-6 md:pt-8 text-center text-white/60 text-sm">
      © 2026 Guild Presidents Leadership Academy. All rights reserved. | guildleaders.academy
    </div>
  </div>
</footer>