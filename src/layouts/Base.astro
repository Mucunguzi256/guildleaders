---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Empowering ethical youth leaders for democratic transformation in East Africa." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} | Guild Presidents Leadership Academy</title>
    
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/guildleaders/assets/images/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/guildleaders/assets/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/guildleaders/assets/images/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/guildleaders/assets/images/apple-touch-icon.png" />
    <link rel="manifest" href="/guildleaders/site.webmanifest" />
    <meta name="theme-color" content="#132d82" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg-base: #F7F6F3;
        --bg-section-alt: #EFEDE8;
        --bg-dark: #132d82;
        --bg-green: #389a29;
        --text-primary: #0D1B0A;
        --text-muted: #5C5C52;
      }
      body { background-color: var(--bg-base); color: var(--text-primary); }
      .bg-gpla-light { background-color: var(--bg-section-alt); }
      
      /* Global Scroll Animations */
      [data-animate] { opacity: 0; transform: translateY(28px); transition: opacity 0.65s cubic-bezier(0.16,1,0.3,1), transform 0.65s cubic-bezier(0.16,1,0.3,1); }
      [data-animate].animate-in { opacity: 1; transform: translateY(0); }
      
      /* Hero Grain */
      .hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        opacity: 0.4;
        z-index: 1;
      }
      
      /* Countdown */
      .countdown-card {
        background: linear-gradient(135deg, #0a1647 0%, #132d82 100%);
        border-top: 3px solid #389a29;
        position: relative;
      }
      .countdown-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
        background-size: 20px 20px;
        pointer-events: none;
      }
      .flip { animation: flip-card 0.15s ease-in-out; }
      @keyframes flip-card {
        0% { transform: rotateX(0deg); }
        50% { transform: rotateX(90deg); }
        100% { transform: rotateX(0deg); }
      }
      
      /* Scroll-driven Summits Section */
      .summits-scroll-section { position: relative; height: 280vh; }
      .summits-sticky { position: sticky; top: 80px; height: calc(100vh - 80px); display: grid; grid-template-columns: 380px 1fr; overflow: hidden; }
      .summits-left { background: #F7F6F3; padding: 60px 40px; display: flex; flex-direction: column; justify-content: center; }
      .section-label { color: #389a29; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; font-size: 12px; margin-bottom: 8px; }
      .section-heading { font-family: 'Bebas Neue', sans-serif; font-size: 56px; line-height: 1.1; color: #132d82; margin-bottom: 48px; }
      .summits-right { position: relative; overflow: hidden; }
      
      /* Summit Panel Transitions - slower, smoother with cubic-bezier */
      .summit-panel { 
        position: relative; 
        color: #fff; 
        display: block; 
        padding: 32px; 
        margin-bottom: 24px;
      }
      .summit-panel.active { 
        /* always visible */
      }
      
      /* Distinct colors per summit - professional, varied palette */
      #summit-2026 { background: linear-gradient(135deg, #0a1628 0%, #132d82 60%, #1a3d5c 100%); }
      #summit-2025 { background: linear-gradient(135deg, #0d2818 0%, #1a4d2e 50%, #389a29 100%); }
      #summit-2024 { background: linear-gradient(135deg, #2d1f0d 0%, #5c3d12 50%, #8b5a2b 100%); }
      
      .panel-inner { max-width: 600px; }
      .panel-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; display: block; margin-bottom: 16px; }
      .panel-title { font-family: 'Bebas Neue', sans-serif; font-size: 52px; line-height: 1.05; margin-bottom: 20px; }
      .panel-theme { font-size: 18px; font-style: italic; opacity: 0.85; margin-bottom: 32px; line-height: 1.5; }
      .panel-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 40px; padding: 24px; background: rgba(255,255,255,0.08); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); }
      .meta-label { font-size: 11px; opacity: 0.6; display: block; letter-spacing: 0.08em; text-transform: uppercase; }
      .meta-value { font-family: 'Bebas Neue', sans-serif; font-size: 24px; display: block; margin: 4px 0 2px; }
      .meta-sub { font-size: 13px; opacity: 0.7; display: block; }
      .panel-actions { display: flex; gap: 12px; flex-wrap: wrap; }
      .panel-cta { padding: 14px 32px; border-radius: 999px; font-weight: 600; font-size: 15px; text-decoration: none; transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, opacity 0.3s ease; }
      .panel-cta:hover { transform: translateY(-3px); box-shadow: 0 12px 24px rgba(0,0,0,0.25); }
      .panel-cta.primary { background: #F5A623; color: #132d82; }
      .panel-cta.ghost { border: 2px solid rgba(255,255,255,0.5); color: #fff; background: rgba(255,255,255,0.05); }
      .panel-cta.ghost:hover { background: rgba(255,255,255,0.15); border-color: #fff; }
      
      /* Summit Navigation - clearer, more tactile */
      .summit-indicators { display: flex; flex-direction: column; gap: 4px; }
      .summit-indicator { 
        display: flex; align-items: flex-start; gap: 16px; 
        padding: 20px 16px; 
        opacity: 0.35; 
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease, transform 0.3s ease;
        cursor: pointer; 
        border-radius: 12px;
        margin: 0 -8px;
      }
      .summit-indicator:hover { 
        opacity: 0.6; 
        background: rgba(19, 45, 130, 0.04);
        transform: translateX(4px);
      }
      .summit-indicator.active { 
        opacity: 1; 
        background: rgba(56, 154, 41, 0.08);
        transform: translateX(8px);
      }
      .indicator-line { 
        width: 4px; height: 48px; 
        background: #d0d0d0; 
        border-radius: 3px; 
        transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1), width 0.3s ease;
        flex-shrink: 0; 
        margin-top: 4px; 
      }
      .summit-indicator.active .indicator-line { 
        background: #389a29; 
        width: 5px;
        box-shadow: 0 0 12px rgba(56, 154, 41, 0.4);
      }
      .indicator-year { 
        font-family: 'Bebas Neue', sans-serif; font-size: 38px; line-height: 1; 
        color: #132d82; display: block; 
        transition: color 0.4s ease;
      }
      .summit-indicator.active .indicator-year { color: #389a29; }
      .indicator-name { font-size: 13px; color: #5C5C52; display: block; margin-top: 4px; }
      .indicator-badge { 
        display: inline-block; font-size: 9px; font-weight: 700; 
        letter-spacing: 0.08em; padding: 4px 10px; border-radius: 999px; margin-top: 8px; 
        transition: transform 0.3s ease;
      }
      .indicator-badge.upcoming { background: #F5A623; color: #132d82; }
      .summit-indicator.active .indicator-badge.upcoming { 
        animation: badge-pulse 2s ease-in-out infinite;
      }
      @keyframes badge-pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }
      .summits-spacer { height: 100vh; }
      
      /* Scroll-driven Sticky Panels (replaces tabs) */
      .scroll-feature {
        position: relative;
        isolation: isolate;
      }
      .scroll-feature--summits { height: calc(3 * 80vh); }
      .scroll-feature--programs { height: calc(4 * 80vh); }
      
      .scroll-feature__sticky {
        position: sticky;
        top: 0;
        height: 100vh;
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 48px;
        align-items: center;
        padding: 0 clamp(24px, 6vw, 80px);
        overflow: hidden;
        isolation: isolate;
      }
      
      .scroll-feature__nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      
      .scroll-feature__nav-item {
        display: block;
        width: 100%;
        text-align: left;
        padding: 16px 20px;
        border: none;
        background: none;
        border-left: 3px solid transparent;
        cursor: pointer;
        transition: border-color 250ms ease, color 250ms ease, background 250ms ease;
        font-size: 1rem;
        color: #6b7280;
        font-family: 'DM Sans', sans-serif;
      }
      .scroll-feature__nav-item:hover {
        color: #132d82;
        background: rgba(19, 45, 130, 0.04);
      }
      .scroll-feature__nav-item.is-active {
        border-left-color: #132d82;
        color: #132d82;
        background: rgba(19, 45, 130, 0.06);
        font-weight: 600;
      }
      
      .scroll-feature__panels {
        position: relative;
        height: 100%;
      }
      
      .scroll-feature__panel {
        position: absolute;
        inset: 0;
        opacity: 0;
        transform: translateX(24px);
        transition: opacity 350ms ease-out, transform 350ms ease-out;
        pointer-events: none;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 24px;
      }
      .scroll-feature__panel.is-active {
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
      }
      
      .scroll-sentinel {
        position: absolute;
        top: 0;
        height: 80vh;
        width: 100%;
        pointer-events: none;
      }
      
      /* Summit Panel Content */
      .summit-panel-content {
        background: #132d82;
        border-radius: 16px;
        padding: 40px;
        color: #fff;
      }
      .summit-panel-content[data-index="0"] { background: linear-gradient(135deg, #0a1628 0%, #132d82 60%, #1a3d5c 100%); }
      .summit-panel-content[data-index="1"] { background: linear-gradient(135deg, #0d2818 0%, #1a4d2e 50%, #389a29 100%); }
      .summit-panel-content[data-index="2"] { background: linear-gradient(135deg, #2d1f0d 0%, #5c3d12 50%, #8b5a2b 100%); }
      
      /* Program Panel Content */
      .program-panel-content {
        background: #132d82;
        border-radius: 16px;
        padding: 40px;
        color: #fff;
      }
      .program-panel-content[data-index="0"] { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #132d82 100%); }
      .program-panel-content[data-index="1"] { background: linear-gradient(135deg, #14532d 0%, #15803d 50%, #22c55e 100%); }
      .program-panel-content[data-index="2"] { background: linear-gradient(135deg, #4a1d4e 0%, #7c3aed 50%, #a855f7 100%); }
      .program-panel-content[data-index="3"] { background: linear-gradient(135deg, #064e3b 0%, #065f46 50%, #10b981 100%); }
      
      /* Panel Content Styling */
      .panel-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; display: block; margin-bottom: 16px; color: #F5A623; }
      .panel-title { font-family: 'Bebas Neue', sans-serif; font-size: 42px; line-height: 1.1; margin-bottom: 16px; }
      .panel-theme { font-size: 16px; font-style: italic; opacity: 0.85; margin-bottom: 24px; line-height: 1.5; }
      .panel-desc { font-size: 16px; line-height: 1.6; margin-bottom: 24px; opacity: 0.9; }
      .panel-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; padding: 20px; background: rgba(255,255,255,0.08); border-radius: 12px; }
      .meta-label { font-size: 11px; opacity: 0.6; display: block; letter-spacing: 0.08em; text-transform: uppercase; }
      .meta-value { font-family: 'Bebas Neue', sans-serif; font-size: 20px; display: block; margin: 4px 0 2px; }
      .meta-sub { font-size: 12px; opacity: 0.7; display: block; }
      .panel-actions { display: flex; gap: 12px; flex-wrap: wrap; }
      .panel-cta { padding: 12px 28px; border-radius: 999px; font-weight: 600; font-size: 14px; text-decoration: none; transition: transform 0.3s ease, box-shadow 0.3s ease; min-height: 44px; display: inline-flex; align-items: center; }
      .panel-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
      .panel-cta.primary { background: #F5A623; color: #132d82; }
      .panel-cta.ghost { border: 2px solid rgba(255,255,255,0.5); color: #fff; }
      .panel-outcomes { margin-bottom: 32px; }
      .outcomes-title { color: #F5A623; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; }
      .outcomes-list { list-style: none; padding: 0; margin: 0; }
      .outcomes-list li { padding: 6px 0; font-size: 14px; display: flex; align-items: flex-start; gap: 8px; }
      .outcomes-list li::before { content: '✓'; color: #F5A623; }
      
      /* Auto-advancing Carousel - STEP 3 */
      .gpla-carousel { position: relative; width: 100%; }
      .gpla-carousel__track { position: relative; width: 100%; min-height: 320px; }
      @media (min-width: 768px) { .gpla-carousel__track { min-height: 380px; } }
      
      .gpla-carousel__slide {
        position: absolute;
        inset: 0;
        width: 100%;
        opacity: 0;
        pointer-events: none;
        transform: scale(1.04);
        transition: opacity 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 600ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
        will-change: opacity, transform;
      }
      .gpla-carousel__slide.is-active { opacity: 1; pointer-events: auto; transform: scale(1); z-index: 1; }
      .gpla-carousel__slide.is-leaving { opacity: 0; transform: scale(1.04); z-index: 0; pointer-events: none; }
      
      .gpla-carousel__dots { display: flex; justify-content: center; gap: 8px; margin-top: 28px; padding-bottom: 4px; }
      .gpla-carousel__dot { width: 8px; height: 8px; border-radius: 50%; background: #cbd5e1; border: none; cursor: pointer; padding: 0; transition: background 300ms ease, width 300ms ease, border-radius 300ms ease; }
      .gpla-carousel__dot.is-active { background: #132d82; width: 24px; border-radius: 4px; }
      .gpla-carousel:hover .gpla-carousel__dot.is-active { box-shadow: 0 0 0 2px rgba(19, 45, 130, 0.25); }
      
      @media (prefers-reduced-motion: reduce) {
        .gpla-carousel__slide { transition: opacity 200ms ease; transform: none !important; }
        .gpla-carousel__slide.is-leaving { transform: none !important; }
      }
      
      /* Click-based Tabs (CrewAI Style) - TASK 1 */
      .summits-tabs-section { background: #F7F6F3; }
      .summit-tabs-nav {
        display: flex;
        justify-content: center;
        gap: 4px;
        margin-bottom: 40px;
        border-bottom: 2px solid #e5e5e5;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
      }
      .summit-tab {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 16px 32px;
        background: transparent;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        top: 2px;
        min-height: 44px;
        min-width: 64px;
      }
      .summit-tab::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 3px;
        background: #389a29;
        transform: scaleX(0);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .summit-tab:hover::after { transform: scaleX(0.5); }
      .summit-tab.active::after { transform: scaleX(1); }
      .summit-tab.active { background: #389a29; color: #fff; border-radius: 8px 8px 0 0; }
      .summit-tab.active .tab-year { color: #fff; }
      .summit-tab.active .tab-label { color: rgba(255,255,255,0.8); }
      .summit-tab.active .tab-badge { background: #fff; color: #389a29; }
      .tab-year { font-family: 'Bebas Neue', sans-serif; font-size: 32px; color: #132d82; line-height: 1; transition: color 0.3s; }
      .tab-label { font-size: 12px; color: #5C5C52; transition: color 0.3s; }
      .tab-badge { 
        font-size: 9px; font-weight: 700; letter-spacing: 0.08em; 
        background: #F5A623; color: #132d82; 
        padding: 2px 8px; border-radius: 999px; 
      }
      .summit-panels { position: relative; }
      /* Cross-fade transitions - TASK 1 */
      .summit-panel-tab {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        opacity: 0;
        transform: translateY(-6px);
        transition: opacity 200ms ease-in, transform 200ms ease-in;
        pointer-events: none;
        visibility: hidden;
      }
      .summit-panel-tab.active {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 300ms ease-out, transform 300ms ease-out;
        pointer-events: all;
        visibility: visible;
      }
      
      /* Tab Panel Content Styling - TASK 1 & 5 */
      .summit-panel-tab {
        background: #132d82;
        border-radius: 16px;
        padding: 40px;
        color: #fff;
        min-height: 400px;
      }
      #panel-2026 { background: linear-gradient(135deg, #0a1628 0%, #132d82 60%, #1a3d5c 100%); }
      #panel-2025 { background: linear-gradient(135deg, #0d2818 0%, #1a4d2e 50%, #389a29 100%); }
      #panel-2024 { background: linear-gradient(135deg, #2d1f0d 0%, #5c3d12 50%, #8b5a2b 100%); }
      .summit-panel-tab .panel-content { max-width: 700px; }
      .summit-panel-tab .panel-tag { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; display: block; margin-bottom: 16px; color: #F5A623; }
      .summit-panel-tab .panel-title { font-family: 'Bebas Neue', sans-serif; font-size: 42px; line-height: 1.1; margin-bottom: 16px; }
      .summit-panel-tab .panel-theme { font-size: 16px; font-style: italic; opacity: 0.85; margin-bottom: 24px; line-height: 1.5; }
      .summit-panel-tab .panel-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px; padding: 20px; background: rgba(255,255,255,0.08); border-radius: 12px; }
      .summit-panel-tab .meta-label { font-size: 11px; opacity: 0.6; display: block; letter-spacing: 0.08em; text-transform: uppercase; }
      .summit-panel-tab .meta-value { font-family: 'Bebas Neue', sans-serif; font-size: 20px; display: block; margin: 4px 0 2px; }
      .summit-panel-tab .meta-sub { font-size: 12px; opacity: 0.7; display: block; }
      .summit-panel-tab .panel-actions { display: flex; gap: 12px; flex-wrap: wrap; }
      .summit-panel-tab .panel-cta { padding: 12px 28px; border-radius: 999px; font-weight: 600; font-size: 14px; text-decoration: none; transition: transform 0.3s ease, box-shadow 0.3s ease; min-height: 44px; display: inline-flex; align-items: center; }
      .summit-panel-tab .panel-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
      .summit-panel-tab .panel-cta.primary { background: #F5A623; color: #132d82; }
      .summit-panel-tab .panel-cta.ghost { border: 2px solid rgba(255,255,255,0.5); color: #fff; }
      /* Mobile stacking for buttons - TASK 5 */
      @media (max-width: 480px) {
        .summit-panel-tab .panel-actions { flex-direction: column; }
        .summit-panel-tab .panel-cta { width: 100%; text-align: center; justify-content: center; }
        .summit-panel-tab .panel-meta { grid-template-columns: 1fr; }
      }
      
      /* Program Tabs - TASK 2 */
      .programs-tabs-section { background: #fff; }
      .program-tabs-nav {
        display: flex;
        justify-content: center;
        gap: 4px;
        margin-bottom: 40px;
        border-bottom: 2px solid #e5e5e5;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
        flex-wrap: wrap;
        position: relative;
      }
      /* Mobile horizontal scroll with fade - TASK 2 */
      @media (max-width: 640px) {
        .program-tabs-nav {
          flex-wrap: nowrap;
          overflow-x: auto;
          justify-content: flex-start;
          padding: 0 16px;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
          mask-image: linear-gradient(to right, transparent, black 24px, black calc(100% - 24px), transparent);
          -webkit-mask-image: linear-gradient(to right, transparent, black 24px, black calc(100% - 24px), transparent);
        }
        .program-tabs-nav::-webkit-scrollbar { display: none; }
      }
      .program-tab {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 16px 24px;
        background: transparent;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        top: 2px;
        min-height: 44px;
        min-width: 64px;
        flex-shrink: 0;
      }
      .program-tab::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 3px;
        background: #F5A623;
        transform: scaleX(0);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .program-tab:hover::after { transform: scaleX(0.5); }
      .program-tab.active::after { transform: scaleX(1); }
      .program-tab.active { background: #F5A623; color: #132d82; border-radius: 8px 8px 0 0; }
      .program-tab.active .tab-name { color: #132d82; }
      .tab-icon { font-size: 24px; line-height: 1; }
      .tab-name { font-family: 'Bebas Neue', sans-serif; font-size: 20px; color: #132d82; }
      .tab-sub { font-size: 11px; color: #5C5C52; }
      /* Short labels on mobile - TASK 2 */
      @media (max-width: 640px) {
        .program-tab .tab-sub { display: none; }
        .program-tab { padding: 12px 16px; min-width: auto; }
      }
      .program-panels { position: relative; }
      /* Cross-fade for programs - TASK 2 */
      .program-panel-tab {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        opacity: 0;
        transform: translateY(-6px);
        transition: opacity 200ms ease-in, transform 200ms ease-in;
        pointer-events: none;
        visibility: hidden;
      }
      .program-panel-tab.active {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 300ms ease-out, transform 300ms ease-out;
        pointer-events: all;
        visibility: visible;
      }
      
      /* Program Panel Styling */
      .program-panel-tab {
        background: #132d82;
        border-radius: 16px;
        padding: 40px;
        color: #fff;
      }
      .program-panel-tab .panel-content { max-width: 700px; margin: 0 auto; }
      .program-panel-tab .panel-title { font-family: 'Bebas Neue', sans-serif; font-size: 36px; line-height: 1.1; margin-bottom: 16px; }
      .program-panel-tab .program-tags { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; justify-content: center; }
      .program-panel-tab .program-tag { background: rgba(255,255,255,0.15); padding: 6px 14px; border-radius: 999px; font-size: 12px; }
      .program-panel-tab .panel-desc { font-size: 16px; line-height: 1.6; margin-bottom: 24px; opacity: 0.9; text-align: center; }
      .program-panel-tab .panel-outcomes { margin-bottom: 32px; }
      .program-panel-tab .outcomes-title { color: #F5A623; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; text-align: center; }
      .program-panel-tab .outcomes-list { list-style: none; padding: 0; margin: 0; text-align: center; }
      .program-panel-tab .outcomes-list li { padding: 8px 0; font-size: 14px; }
      .program-panel-tab .panel-cta { display: inline-block; padding: 14px 32px; border-radius: 999px; font-weight: 600; font-size: 15px; text-decoration: none; transition: transform 0.3s ease, box-shadow 0.3s ease; text-align: center; }
      .program-panel-tab .panel-cta:hover { transform: translateY(-3px); box-shadow: 0 12px 24px rgba(0,0,0,0.25); }
      .program-panel-tab .panel-cta.primary { background: #F5A623; color: #132d82; }
      
      /* Distinct colors per program */
      #prog-tlb { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #132d82 100%); }
      #prog-pgil { background: linear-gradient(135deg, #14532d 0%, #15803d 50%, #22c55e 100%); }
      #prog-herpower { background: linear-gradient(135deg, #4a1d4e 0%, #7c3aed 50%, #a855f7 100%); }
      #prog-summit { background: linear-gradient(135deg, #064e3b 0%, #065f46 50%, #10b981 100%); }
      
      /* Scroll-driven Programs Section */
      .programs-scroll-section { position: relative; height: 320vh; }
      .programs-sticky { position: sticky; top: 80px; height: calc(100vh - 80px); display: grid; grid-template-columns: 380px 1fr; overflow: hidden; }
      .programs-left { background: #F7F6F3; padding: 60px 40px; display: flex; flex-direction: column; justify-content: center; }
      .programs-right { position: relative; overflow: hidden; }
      
      /* Program Panel Transitions */
      .program-panel { 
        position: relative; 
        color: #fff; 
        display: block; 
        padding: 32px; 
        margin-bottom: 24px;
      }
      .program-panel.active { 
        /* always visible */
      }
      
      /* Distinct professional color schemes for programs */
      #program-tlb { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #132d82 100%); }
      #program-pgil { background: linear-gradient(135deg, #14532d 0%, #15803d 50%, #22c55e 100%); }
      #program-herpower { background: linear-gradient(135deg, #4a1d4e 0%, #7c3aed 50%, #a855f7 100%); }
      #program-summit { background: linear-gradient(135deg, #064e3b 0%, #065f46 50%, #10b981 100%); }
      
      .program-tags { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
      .program-tag { background: rgba(255,255,255,0.15); padding: 6px 14px; border-radius: 999px; font-size: 12px; }
      .panel-desc { font-size: 16px; line-height: 1.6; margin-bottom: 24px; opacity: 0.9; }
      .panel-outcomes { margin-bottom: 32px; }
      .outcomes-title { color: #F5A623; font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px; }
      .outcomes-list { list-style: none; padding: 0; margin: 0; }
      .outcomes-list li { padding: 6px 0; font-size: 14px; }
      
      /* Program Navigation */
      .program-indicators { display: flex; flex-direction: column; gap: 4px; }
      .program-indicator { 
        display: flex; align-items: flex-start; gap: 16px; 
        padding: 20px 16px; 
        opacity: 0.35; 
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease, transform 0.3s ease;
        cursor: pointer; 
        border-radius: 12px;
        margin: 0 -8px;
      }
      .program-indicator:hover { 
        opacity: 0.6; 
        background: rgba(19, 45, 130, 0.04);
        transform: translateX(4px);
      }
      .program-indicator.active { 
        opacity: 1; 
        background: rgba(245, 166, 35, 0.1);
        transform: translateX(8px);
      }
      .program-indicator .indicator-line { 
        background: #d0d0d0; 
        transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1), width 0.3s ease;
      }
      .program-indicator.active .indicator-line { 
        background: #F5A623; 
        width: 5px;
        box-shadow: 0 0 12px rgba(245, 166, 35, 0.4);
      }
      .indicator-icon { font-size: 24px; display: block; margin-bottom: 4px; }
      .indicator-sub { font-size: 11px; color: #5C5C52; display: block; }
      .programs-spacer { height: 100vh; }
      
      /* Gallery */
      .gallery-filters { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
      .filter-btn { background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #fff; padding: 8px 20px; border-radius: 999px; font-size: 13px; cursor: pointer; transition: all 0.2s; }
      .filter-btn.active, .filter-btn:hover { background: #389a29; border-color: #389a29; }
      .gallery-grid { columns: 3 300px; column-gap: 12px; }
      .gallery-item { break-inside: avoid; margin-bottom: 12px; overflow: hidden; border-radius: 8px; cursor: pointer; }
      .gallery-img { width: 100%; height: auto; display: block; transition: transform 0.4s ease; }
      .gallery-item:hover .gallery-img { transform: scale(1.04); }
      
      .gallery-placeholder { background: linear-gradient(135deg, #132d82, #389a29); border-radius: 8px; padding: 40px 20px; text-align: center; break-inside: avoid; margin-bottom: 12px; }
      .gallery-placeholder p { color: #fff; font-family: 'Bebas Neue', sans-serif; font-size: 18px; }
      .gallery-placeholder span { color: rgba(255,255,255,0.5); font-size: 11px; }
      
      .lightbox { position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 9999; display: flex; align-items: center; justify-content: center; }
      .lightbox.hidden { display: none; }
      .lightbox img { max-width: 90vw; max-height: 90vh; object-fit: contain; border-radius: 8px; }
      .lightbox-close { position: absolute; top: 24px; right: 24px; color: white; font-size: 28px; background: none; border: none; cursor: pointer; }
      
      /* Video */
      .video-section { background: #132d82; }
      .video-wrapper { position: relative; padding-bottom: 56.25%; height: 0; border-radius: 12px; overflow: hidden; }
      .video-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
      
      /* Mobile Responsive */
      @media (max-width: 768px) {
        .summits-scroll-section, .programs-scroll-section { height: auto; }
        .summits-sticky, .programs-sticky { 
          position: static; 
          grid-template-columns: 1fr; 
          height: auto; 
        }
        
        /* Left panel - navigation stacked */
        .summits-left, .programs-left { 
          padding: 32px 20px; 
          order: 1;
        }
        .section-heading { font-size: 36px; margin-bottom: 24px; }
        .section-label { font-size: 11px; }
        
        /* Indicators - horizontal scroll on mobile */
        .summit-indicators, .program-indicators { 
          flex-direction: row; 
          overflow-x: auto; 
          gap: 8px;
          padding-bottom: 8px;
          -webkit-overflow-scrolling: touch;
          scroll-snap-type: x mandatory;
        }
        .summit-indicator, .program-indicator { 
          flex: 0 0 auto;
          min-width: 100px;
          padding: 12px 16px;
          scroll-snap-align: start;
          flex-direction: column;
          gap: 8px;
        }
        .indicator-line { 
          width: 32px; height: 3px; 
          margin-top: 0;
        }
        .summit-indicator.active .indicator-line, 
        .program-indicator.active .indicator-line { width: 32px; }
        .indicator-year { font-size: 28px; }
        .indicator-name { font-size: 11px; margin-top: 2px; }
        .indicator-badge { font-size: 8px; padding: 2px 6px; margin-top: 4px; }
        
        /* Right panel - content */
        .summits-right, .programs-right { 
          height: 520px; 
          position: relative; 
          order: 2;
        }
        .summit-panel, .program-panel { 
          padding: 28px 20px; 
          display: flex;
          align-items: flex-start;
        }
        .panel-inner { max-width: 100%; }
        .panel-title { font-size: 28px; margin-bottom: 12px; }
        .panel-tag { font-size: 10px; margin-bottom: 12px; }
        .panel-theme { font-size: 14px; margin-bottom: 20px; }
        .panel-meta { 
          grid-template-columns: 1fr; 
          gap: 16px; 
          padding: 16px; 
          margin-bottom: 20px;
        }
        .meta-value { font-size: 18px; }
        .meta-label, .meta-sub { font-size: 10px; }
        .panel-actions { flex-direction: column; gap: 10px; }
        .panel-cta { 
          padding: 12px 24px; 
          font-size: 14px; 
          text-align: center;
        }
        
        /* Spacer */
        .summits-spacer, .programs-spacer { height: 50vh; }
        
        /* Gallery */
        .gallery-grid { columns: 1; }
      }
      
      /* Extra small devices */
      @media (max-width: 480px) {
        .summits-right, .programs-right { height: 480px; }
        .panel-title { font-size: 24px; }
        .section-heading { font-size: 28px; }
      }
      
      /* Mobile layout for scroll feature (< 1024px) */
      @media (max-width: 1023px) {
        .scroll-feature--summits, .scroll-feature--programs {
          height: auto;
        }
        .scroll-feature__sticky {
          position: static;
          display: flex;
          flex-direction: column;
          gap: 0;
          padding: 0;
          height: auto;
          overflow: visible;
        }
        .scroll-feature__nav {
          display: none;
        }
        .scroll-feature__panels {
          position: static;
          height: auto;
        }
        .scroll-feature__panel {
          position: static;
          opacity: 0;
          transform: translateY(32px);
          transition: opacity 400ms ease-out, transform 400ms ease-out;
          pointer-events: auto;
          padding: 24px 20px;
          margin-bottom: 16px;
          border: 1px solid rgba(19, 45, 130, 0.12);
          border-radius: 12px;
          background: #fff;
        }
        .scroll-feature__panel.is-active {
          opacity: 1;
          transform: translateY(0);
        }
        .scroll-feature__panel.is-visible {
          opacity: 1;
          transform: translateY(0);
        }
        /* Mobile card styles */
        .summit-panel-content, .program-panel-content {
          padding: 24px 20px;
          border-radius: 12px;
          background: #132d82;
        }
        .summit-panel-content[data-index="0"], .program-panel-content[data-index="0"] { background: linear-gradient(135deg, #0a1628 0%, #132d82 100%); }
        .summit-panel-content[data-index="1"], .program-panel-content[data-index="1"] { background: linear-gradient(135deg, #0d2818 0%, #1a4d2e 100%); }
        .summit-panel-content[data-index="2"], .program-panel-content[data-index="2"] { background: linear-gradient(135deg, #14532d 0%, #15803d 100%); }
        .program-panel-content[data-index="3"] { background: linear-gradient(135deg, #064e3b 0%, #065f46 100%); }
        
        /* Stagger delays for mobile cards */
        .scroll-feature__panel:nth-child(1) { transition-delay: 0ms; }
        .scroll-feature__panel:nth-child(2) { transition-delay: 100ms; }
        .scroll-feature__panel:nth-child(3) { transition-delay: 200ms; }
        .scroll-feature__panel:nth-child(4) { transition-delay: 300ms; }
      }
      
      /* Reduced motion */
      @media (prefers-reduced-motion: no-preference) {
        .scroll-feature__panel {
          will-change: transform, opacity;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .scroll-feature__panel {
          transition: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
      }
      
      /* Touch devices - larger tap targets */
      @media (hover: none) {
        .summit-indicator, .program-indicator { 
          padding: 16px 20px; 
        }
        .panel-cta { 
          min-height: 48px;
          display: flex;
          align-items: center;
          justify-content: center;
        }
      }
      
      /* Scroll Animations - TASK 3 */
      .fade-in-up {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 400ms ease-out, transform 400ms ease-out;
        will-change: opacity, transform;
      }
      .fade-in-up.visible {
        opacity: 1;
        transform: translateY(0);
      }
      /* Stagger delays */
      .stagger-1 { transition-delay: 80ms; }
      .stagger-2 { transition-delay: 160ms; }
      .stagger-3 { transition-delay: 240ms; }
      .stagger-4 { transition-delay: 320ms; }
      .stagger-5 { transition-delay: 400ms; }
      .stagger-6 { transition-delay: 480ms; }
      
      /* Stats Counter - TASK 4 */
      .stats-counter {
        will-change: transform;
      }
      
      /* Announcement Marquee Mobile - TASK 8 */
      @media (max-width: 480px) {
        .announcement-ticker {
          font-size: 12px;
          padding: 6px 0;
        }
      }
      
      /* Partner logos marquee - TASK 8 */
      .partners-marquee {
        display: flex;
        will-change: transform;
      }
      
      /* Mobile nav smooth open - TASK 8 */
      #mobile-menu {
        transition: opacity 200ms ease, transform 200ms ease;
      }
      #mobile-menu.hidden {
        opacity: 0;
        transform: translateY(-10px);
        pointer-events: none;
      }
      #mobile-menu:not(.hidden) {
        opacity: 1;
        transform: translateY(0);
      }
      
      /* Countdown Timer - TASK 7 */
      .countdown-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
      }
      .countdown-unit {
        background: rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 16px 8px;
        text-align: center;
        min-width: 72px;
      }
      .countdown-number {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(2rem, 8vw, 3.5rem);
        line-height: 1;
        display: block;
      }
      .countdown-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        opacity: 0.7;
        display: block;
        margin-top: 4px;
      }
      @media (max-width: 400px) {
        .countdown-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 16px;
        }
      }
      
      /* prefers-reduced-motion - TASK 3 */
      @media (prefers-reduced-motion: reduce) {
        .fade-in-up {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
        .summit-panel-tab, .program-panel-tab {
          transition: none !important;
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>
  </head>
  <body class="font-body text-gray-900 bg-[var(--bg-base)] overflow-x-hidden">
    <slot />
    <script>
      // TASK 3: Scroll-triggered fade-up animations with prefers-reduced-motion check
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      
      if (!prefersReducedMotion) {
        const scrollAnimator = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            // Add will-change before animation
            entry.target.style.willChange = 'transform, opacity';
            const delay = parseInt(entry.target.dataset.delay) || 0;
            setTimeout(() => {
              entry.target.classList.add('visible');
              // Remove will-change after animation completes
              setTimeout(() => {
                entry.target.style.willChange = '';
              }, 400);
            }, delay);
            scrollAnimator.unobserve(entry.target);
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('[data-animate], .fade-in-up').forEach(el => scrollAnimator.observe(el));
      } else {
        // Immediately show elements if reduced motion preferred
        document.querySelectorAll('[data-animate], .fade-in-up').forEach(el => {
          el.classList.add('visible');
        });
      }
      
      // TASK 4: Stats counter with easeOutQuart over 1800ms
      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting || entry.target.dataset.counted) return;
          entry.target.dataset.counted = 'true';
          entry.target.style.willChange = 'transform';
          
          const target = parseInt(entry.target.dataset.count);
          const suffix = entry.target.dataset.suffix || '';
          const duration = 1800;
          const startTime = performance.now();
          
          // easeOutQuart: 1 - (1 - t)^4
          const easeOutQuart = t => 1 - Math.pow(1 - t, 4);
          
          const tick = (now) => {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const current = Math.floor(easeOutQuart(progress) * target);
            entry.target.textContent = current + suffix;
            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              entry.target.style.willChange = '';
            }
          };
          requestAnimationFrame(tick);
        });
      }, { threshold: 0.3 });
      document.querySelectorAll('[data-count]').forEach(el => statsObserver.observe(el));
    </script>
  </body>
